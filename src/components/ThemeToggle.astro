---
// Theme Toggle Component
---

<div class="relative">
  <button 
    id="theme-toggle-btn"
    class="flex items-center gap-2 px-3 py-2 rounded-lg bg-[var(--bg-tertiary)] border border-[var(--border-color)] text-[var(--text-primary)] hover:border-[var(--accent-primary)] transition-colors z-50"
    aria-label="Change theme"
  >
    <span id="theme-icon">🌙</span>
    <span id="theme-name" class="text-sm hidden sm:inline">Dark</span>
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-1"><path d="m6 9 6 6 6-6"/></svg>
  </button>
  
  <div 
    id="theme-menu" 
    class="hidden absolute right-0 top-full mt-2 w-48 bg-[var(--bg-secondary)] border border-[var(--border-color)] rounded-lg shadow-lg z-50 overflow-hidden"
  >
    <div class="p-2">
      <p class="text-[var(--text-muted)] text-xs px-3 py-2 uppercase tracking-wider">Choose Theme</p>
      
      <button class="theme-option w-full text-left px-3 py-2 rounded-lg hover:bg-[var(--bg-tertiary)] text-[var(--text-primary)] text-sm flex items-center gap-3 transition-colors" data-theme="dark">
        <span>🌙</span> Dark
      </button>
      
      <button class="theme-option w-full text-left px-3 py-2 rounded-lg hover:bg-[var(--bg-tertiary)] text-[var(--text-primary)] text-sm flex items-center gap-3 transition-colors" data-theme="light">
        <span>☀️</span> Light
      </button>
      
      <button class="theme-option w-full text-left px-3 py-2 rounded-lg hover:bg-[var(--bg-tertiary)] text-[var(--text-primary)] text-sm flex items-center gap-3 transition-colors" data-theme="ocean">
        <span>🌊</span> Ocean
      </button>
      
      <button class="theme-option w-full text-left px-3 py-2 rounded-lg hover:bg-[var(--bg-tertiary)] text-[var(--text-primary)] text-sm flex items-center gap-3 transition-colors" data-theme="sunset">
        <span>🌅</span> Sunset
      </button>
      
      <button class="theme-option w-full text-left px-3 py-2 rounded-lg hover:bg-[var(--bg-tertiary)] text-[var(--text-primary)] text-sm flex items-center gap-3 transition-colors" data-theme="forest">
        <span>🌲</span> Forest
      </button>
      
      <div class="border-t border-[var(--border-color)] my-2"></div>
      
      <button class="theme-option w-full text-left px-3 py-2 rounded-lg hover:bg-[var(--bg-tertiary)] text-[var(--text-primary)] text-sm flex items-center gap-3 transition-colors" data-theme="contrast">
        <span>⚡</span> High Contrast
      </button>
    </div>
  </div>
</div>

<script>
  const themeIcons: Record<string, string> = {
    dark: '🌙',
    light: '☀️',
    ocean: '🌊',
    sunset: '🌅',
    forest: '🌲',
    contrast: '⚡'
  };
  
  const themeNames: Record<string, string> = {
    dark: 'Dark',
    light: 'Light',
    ocean: 'Ocean',
    sunset: 'Sunset',
    forest: 'Forest',
    contrast: 'High Contrast'
  };
  
  // Initialize theme
  function initTheme() {
    const savedTheme = localStorage.getItem('guildpost-theme');
    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    const defaultTheme = savedTheme || (prefersDark ? 'dark' : 'light');
    
    setTheme(defaultTheme);
  }
  
  const themeColors: Record<string, string> = {
    dark: '#0a0a0f',
    light: '#f8fafc',
    ocean: '#0c1220',
    sunset: '#1a0b0e',
    forest: '#0d1912',
    contrast: '#000000'
  };
  
  const rgbValues: Record<string, string> = {
    dark: '10, 10, 15',
    light: '248, 250, 252',
    ocean: '12, 18, 32',
    sunset: '26, 11, 14',
    forest: '13, 25, 18',
    contrast: '0, 0, 0'
  };
  
  const accentRgbValues: Record<string, Record<string, string>> = {
    dark: { primary: '0, 245, 212', secondary: '255, 56, 100', tertiary: '168, 85, 247' },
    light: { primary: '8, 145, 178', secondary: '225, 29, 72', tertiary: '124, 58, 237' },
    ocean: { primary: '59, 130, 246', secondary: '139, 92, 246', tertiary: '6, 182, 212' },
    sunset: { primary: '249, 115, 22', secondary: '236, 72, 153', tertiary: '251, 191, 36' },
    forest: { primary: '16, 185, 129', secondary: '132, 204, 22', tertiary: '20, 184, 166' },
    contrast: { primary: '255, 255, 0', secondary: '0, 255, 255', tertiary: '255, 0, 255' }
  };
  
  function setTheme(theme: string) {
    document.documentElement.setAttribute('data-theme', theme);
    localStorage.setItem('guildpost-theme', theme);
    
    const iconEl = document.getElementById('theme-icon');
    const nameEl = document.getElementById('theme-name');
    
    if (iconEl) iconEl.textContent = themeIcons[theme] || '🌙';
    if (nameEl) nameEl.textContent = themeNames[theme] || 'Dark';
    
    // Update meta theme-color for mobile browsers
    const metaThemeColor = document.getElementById('theme-color-meta');
    if (metaThemeColor && themeColors[theme]) {
      metaThemeColor.setAttribute('content', themeColors[theme]);
    }
    
    // Update RGB values for transparent backgrounds
    document.documentElement.style.setProperty('--bg-primary-rgb', rgbValues[theme] || rgbValues.dark);
    
    // Update accent RGB values
    const accents = accentRgbValues[theme] || accentRgbValues.dark;
    document.documentElement.style.setProperty('--accent-primary-rgb', accents.primary);
    document.documentElement.style.setProperty('--accent-secondary-rgb', accents.secondary);
    document.documentElement.style.setProperty('--accent-tertiary-rgb', accents.tertiary);
  }
  
  // Toggle menu
  const toggleBtn = document.getElementById('theme-toggle-btn');
  const themeMenu = document.getElementById('theme-menu');
  
  toggleBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    themeMenu?.classList.toggle('hidden');
  });
  
  // Close menu when clicking outside
  document.addEventListener('click', () => {
    themeMenu?.classList.add('hidden');
  });
  
  // Theme selection
  document.querySelectorAll('.theme-option').forEach(btn => {
    btn.addEventListener('click', () => {
      const theme = btn.getAttribute('data-theme') || 'dark';
      setTheme(theme);
      themeMenu?.classList.add('hidden');
    });
  });
  
  // Listen for system theme changes
  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
    if (!localStorage.getItem('guildpost-theme')) {
      setTheme(e.matches ? 'dark' : 'light');
    }
  });
  
  // Initialize
  initTheme();
</script>