---
// New Servers Component - Homepage section for recently added servers
// Displays the newest servers to help fresh communities get visibility

interface Props {
  servers: Array<{
    id: string;
    name: string;
    ip: string;
    port: number;
    description?: string;
    players_online?: number;
    max_players?: number;
    vote_count?: number;
    status?: string;
    banner?: string;
    icon?: string;
    tags?: string[];
    tier?: string;
    rating_average?: number;
    rating_count?: number;
    created_at?: string;
  }>;
}

const { servers } = Astro.props;

// Format player count for display
const formatPlayers = (online: number = 0, max: number = 0) => {
  if (max === 0) return `${online} online`;
  return `${online.toLocaleString()}/${max.toLocaleString()}`;
};

// Format relative time (e.g., "2 days ago")
const getRelativeTime = (dateString?: string): string => {
  if (!dateString) return '';
  const date = new Date(dateString);
  const now = new Date();
  const diffMs = now.getTime() - date.getTime();
  const diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));
  const diffHours = Math.floor(diffMs / (1000 * 60 * 60));
  const diffMinutes = Math.floor(diffMs / (1000 * 60));
  
  if (diffMinutes < 60) return `${diffMinutes}m ago`;
  if (diffHours < 24) return `${diffHours}h ago`;
  if (diffDays === 1) return 'Yesterday';
  if (diffDays < 7) return `${diffDays} days ago`;
  if (diffDays < 30) return `${Math.floor(diffDays / 7)}w ago`;
  return `${Math.floor(diffDays / 30)}mo ago`;
};
---

{servers.length > 0 && (
  <section class="py-12" aria-labelledby="new-servers-heading">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h2 id="new-servers-heading" class="text-2xl font-bold text-white flex items-center gap-2">
          <span class="text-green-400">●</span>
          New Servers
        </h2>
        <p class="text-[#8892b0] text-sm mt-1">
          Fresh communities recently added to GuildPost
        </p>
      </div>
      <a 
        href="/minecraft?sort=newest" 
        class="text-sm text-[#00f5d4] hover:underline flex items-center gap-1"
      >
        View all new
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14"/>
          <path d="m12 5 7 7-7 7"/>
        </svg>
      </a>
    </div>

    <div class="grid gap-4 grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
      {servers.map((server) => (
        <a 
          href={`/servers/${server.id}`}
          class="group bg-[#12121a] border border-[#2a2a3a] rounded-lg overflow-hidden hover:border-[#00f5d4] transition-all duration-300"
        >
          {/* Banner */}
          <div class="relative h-28 overflow-hidden">
            {server.banner ? (
              <img 
                src={server.banner} 
                alt={`${server.name} banner`}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
            ) : (
              <div class="w-full h-full bg-gradient-to-br from-[#00f5d4]/10 to-[#ff3864]/10 flex items-center justify-center">
                <span class="text-4xl">⛏</span>
              </div>
            )}
            
            {/* Status Badge */}
            <div class="absolute top-3 right-3">
              <span class={`px-2 py-1 rounded text-xs font-medium ${
                server.status === 'online' 
                  ? 'bg-green-500/20 text-green-400' 
                  : 'bg-red-500/20 text-red-400'
              }`}>
                {server.status === 'online' ? '● Online' : '○ Offline'}
              </span>
            </div>

            {/* NEW Badge */}
            <div class="absolute top-3 left-3">
              <span class="px-2 py-1 rounded text-xs font-medium bg-green-500/20 text-green-400 animate-pulse">
                ● NEW
              </span>
            </div>
          </div>

          {/* Content */}
          <div class="p-4">
            <div class="flex items-start gap-3">
              {server.icon ? (
                <img 
                  src={server.icon} 
                  alt=""
                  class="w-10 h-10 rounded-lg object-cover flex-shrink-0 bg-[#0a0a0f]"
                  loading="lazy"
                />
              ) : (
                <div class="w-10 h-10 rounded-lg bg-[#0a0a0f] flex items-center justify-center flex-shrink-0">
                  <span class="text-[#00f5d4]">⛏</span>
                </div>
              )}
              
              <div class="flex-1 min-w-0">
                <h3 class="font-semibold text-white group-hover:text-[#00f5d4] transition-colors truncate">
                  {server.name}
                </h3>
                {/* Star rating display */}
                {server.rating_average && server.rating_count && server.rating_count > 0 && (
                  <div class="flex items-center gap-1 text-xs mb-1">
                    <span class="text-yellow-400">
                      {'★'.repeat(Math.round(server.rating_average))}{'☆'.repeat(5 - Math.round(server.rating_average))}
                    </span>
                    <span class="text-[#8892b0]">({server.rating_count})</span>
                  </div>
                )}
                <p class="text-xs text-[#8892b0] font-mono truncate">
                  {server.ip}:{server.port}
                </p>
              </div>
            </div>

            {server.description && (
              <p class="text-sm text-[#8892b0] mt-3 line-clamp-2">
                {server.description}
              </p>
            )}

            {/* Stats */}
            <div class="flex items-center gap-4 mt-3 pt-3 border-t border-[#2a2a3a]">
              <span class="text-xs text-[#8892b0] flex items-center gap-1">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
                  <circle cx="9" cy="7" r="4"/>
                  <path d="M22 21v-2a4 4 0 0 0-3-3.87"/>
                  <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
                {formatPlayers(server.players_online, server.max_players)}
              </span>
              
              <span class="text-xs text-[#ff3864] flex items-center gap-1">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M7 10v12"/>
                  <path d="M15 5.88 14 10h5.83a2 2 0 0 1 1.92 2.56l-2.33 8A2 2 0 0 1 17.5 22 4 4 0 0 1 15 19H8.17"/>
                </svg>
                {server.vote_count?.toLocaleString() || 0} votes
              </span>

              {/* Added time */}
              {server.created_at && (
                <span class="text-xs text-green-400 flex items-center gap-1 ml-auto">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/>
                    <polyline points="12 6 12 12 16 14"/>
                  </svg>
                  {getRelativeTime(server.created_at)}
                </span>
              )}
            </div>

            {/* Tags */}
            {server.tags && server.tags.length > 0 && (
              <div class="flex flex-wrap gap-1 mt-3">
                {server.tags.slice(0, 3).map((tag) => (
                  <span class="px-2 py-0.5 bg-[#1a1a25] rounded text-xs text-[#00f5d4]">
                    {tag}
                  </span>
                ))}
                {server.tags.length > 3 && (
                  <span class="px-2 py-0.5 text-xs text-[#8892b0]">
                    +{server.tags.length - 3}
                  </span>
                )}
              </div>
            )}
          </div>
        </a>
      ))}
    </div>
  </section>
)}

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "New Minecraft Servers",
  "itemListElement": servers.map((server, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "item": {
      "@type": "GameServer",
      "name": server.name,
      "url": `https://guildpost.tech/servers/${server.id}`,
      "game": {
        "@type": "VideoGame",
        "name": "Minecraft"
      },
      "playerCount": {
        "@type": "QuantitativeValue",
        "value": server.players_online || 0
      },
      "dateCreated": server.created_at
    }
  }))
})} />
