---
import ThemeToggle from './ThemeToggle.astro';

const navItems = [
  { label: 'Minecraft', href: '/minecraft' },
  { label: 'Wizard', href: '/wizard', icon: '🔮' },
  { label: 'Discover', href: '/discover' },
  { label: 'Uptime', href: '/uptime', icon: '⏱️' },
  { label: 'Events', href: '/events', icon: '📅' },
  { label: 'Banner Maker', href: '/banner-maker', icon: '🎨' },
  { label: 'Premium', href: '/premium', icon: '⭐' },
  { label: 'Categories', href: '/minecraft#categories' },
  { label: 'Favorites', href: '/favorites', icon: '♡' },
  { label: 'Dashboard', href: '/dashboard', icon: '📊' },
  { label: 'Add Server', href: '/submit', highlight: true },
];
---

<header class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md border-b border-[var(--border-color)] transition-colors duration-300 bg-[var(--bg-primary)]/90">
  <div class="max-w-6xl mx-auto px-4">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 group">
        <img src="/logo.png" alt="Guild Post" class="h-8 w-auto" />
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-6">
        {navItems.map((item) => (
          <a
            href={item.href}
            class={`transition-all duration-200 font-medium hover:opacity-80 ${
              item.highlight
                ? 'px-4 py-2 rounded-lg bg-[var(--accent-primary)] text-[var(--bg-primary)]'
                : 'text-[var(--text-secondary)] hover:text-[var(--text-primary)]'
            }`}
          >
            {item.icon && <span class="mr-1">{item.icon}</span>}
            {item.label}
          </a>
        ))}
      </nav>

      <!-- CTA & Mobile Menu -->
      <div class="flex items-center gap-4">
        <!-- Theme Toggle -->
        <ThemeToggle />
        
        <a
          href="/minecraft"
          class="hidden sm:inline-flex items-center gap-2 px-4 py-2 font-medium rounded-lg transition-all duration-200 text-sm bg-[var(--accent-secondary)] text-white hover:opacity-90"
        >
          Browse Servers
        </a>
        
        <!-- Mobile menu button -->
        <button
          id="mobile-menu-btn"
          class="md:hidden p-2 text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors"
          aria-label="Toggle menu"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Nav -->
    <div id="mobile-menu" class="hidden md:hidden py-4 border-t border-[var(--border-color)] transition-colors">
      <nav class="flex flex-col gap-3">
        <a href="/minecraft" class="text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors font-medium">
          Minecraft Servers
        </a>
        <a href="/favorites" class="text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors font-medium flex items-center gap-2">
          <span>♡</span> Favorites
        </a>
        <a href="/dashboard" class="text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors font-medium flex items-center gap-2">
          <span>📊</span> Dashboard
        </a>
        <a href="/submit" class="text-[var(--accent-primary)] hover:opacity-80 transition-all font-medium">
          + Add Your Server
        </a>
        <a href="/minecraft" class="px-4 py-2 font-medium rounded-lg transition-all duration-200 text-center text-sm bg-[var(--accent-secondary)] text-white hover:opacity-90">
          Browse All Servers
        </a>
      </nav>
    </div>
  </div>
</header>

<script>
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  mobileMenuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>