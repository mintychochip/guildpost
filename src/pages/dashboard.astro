---
// Server Owner Dashboard - Analytics, edit server, vote stats with real authentication
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export const prerender = false;
---

<Layout 
  title="Server Dashboard - Manage Your Server | GuildPost"
  description="Manage your Minecraft server on GuildPost. View analytics, edit details, and track votes with verified ownership."
  url="https://guildpost.tech/dashboard"
>
  <div class="min-h-screen bg-[#0a0a0f]">
    <Header />
    
    <main class="max-w-6xl mx-auto px-4 py-8">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm text-[#8892b0] mb-6">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <span class="text-white">Dashboard</span>
      </nav>

      <h1 class="text-4xl font-black text-white mb-2">Server Dashboard</h1>
      <p class="text-[#8892b0] text-lg mb-8">Manage your servers, view analytics, and track performance.</p>

      <!-- Auth Section (shown when not authenticated) -->
      <div id="auth-section" class="mb-8">
        <div class="p-6 bg-[#12121a] border border-[#2a2a3a] rounded-lg">
          <h2 class="text-xl font-bold text-white mb-4">Claim Your Server</h2>
          <p class="text-[#8892b0] mb-4">
            Enter your server ID to claim ownership. You'll need to verify by adding a token to your server's MOTD.
          </p>
          
          <div class="flex flex-col md:flex-row gap-4">
            <input 
              type="text" 
              id="server-id-input" 
              placeholder="Enter your server ID (e.g., mc.example.com:25565)"
              class="flex-1 px-4 py-3 bg-[#0a0a0f] border border-[#2a2a3a] rounded-lg text-white placeholder-[#8892b0] focus:outline-none focus:border-[#00f5d4]"
            >
            <input
              type="email"
              id="owner-email-input"
              placeholder="Your email (optional, for ownership)"
              class="flex-1 px-4 py-3 bg-[#0a0a0f] border border-[#2a2a3a] rounded-lg text-white placeholder-[#8892b0] focus:outline-none focus:border-[#00f5d4]"
            >
          </div>
          
          <div class="mt-4">
            <button 
              id="claim-server-btn"
              class="px-6 py-3 bg-[#00f5d4] hover:bg-[#00d4b8] text-[#0a0a0f] font-bold rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
            >
              <span id="claim-btn-text">Start Verification</span>
              <span id="claim-btn-spinner" class="hidden">⏳</span>
            </button>
          </div>
          
          <p class="text-[#8892b0] text-sm mt-3">
            Don't know your server ID? <a href="/minecraft" class="text-[#00f5d4] hover:underline">Find your server</a> and copy the ID from the URL.
          </p>
        </div>
      </div>

      <!-- Verification Progress (shown during verification) -->
      <div id="verification-section" class="hidden mb-8">
        <div class="p-6 bg-[#12121a] border border-[#2a2a3a] rounded-lg">
          <h2 class="text-xl font-bold text-white mb-4">Verify Server Ownership</h2>
          
          <div id="verification-steps" class="space-y-4">
            <!-- Step 1: Show Token -->
            <div id="step-1" class="p-4 bg-[#0a0a0f] rounded-lg border border-[#2a2a3a]">
              <div class="flex items-center gap-2 mb-2">
                <span class="w-6 h-6 rounded-full bg-[#00f5d4] text-[#0a0a0f] flex items-center justify-center text-sm font-bold">1</span>
                <span class="text-white font-medium">Copy your verification token</span>
              </div>
              <div class="mt-3 p-3 bg-[#1a1a25] rounded border border-[#00f5d4]/30">
                <code id="verification-token" class="text-[#00f5d4] text-sm break-all font-mono">...</code>
                <button id="copy-token-btn" class="ml-2 text-[#8892b0] hover:text-white text-xs">Copy</button>
              </div>
              <p class="text-[#8892b0] text-sm mt-2">Token expires in 24 hours</p>
            </div>

            <!-- Step 2: Add to MOTD -->
            <div id="step-2" class="p-4 bg-[#0a0a0f] rounded-lg border border-[#2a2a3a]">
              <div class="flex items-center gap-2 mb-2">
                <span class="w-6 h-6 rounded-full bg-[#2a2a3a] text-white flex items-center justify-center text-sm font-bold">2</span>
                <span class="text-white font-medium">Add token to your server.properties</span>
              </div>
              <div class="mt-3 space-y-2">
                <p class="text-[#8892b0] text-sm">Open your <code class="bg-[#1a1a25] px-1 rounded">server.properties</code> file and update:</p>
                <div class="p-3 bg-[#1a1a25] rounded border border-[#2a2a3a] font-mono text-sm text-[#8892b0]">
                  motd=§aMy Server §7| §fVerification: <span class="text-[#00f5d4]">YOUR_TOKEN_HERE</span>
                </div>
                <p class="text-[#8892b0] text-sm">Or add the full token anywhere in your MOTD.</p>
              </div>
            </div>

            <!-- Step 3: Verify -->
            <div id="step-3" class="p-4 bg-[#0a0a0f] rounded-lg border border-[#2a2a3a]">
              <div class="flex items-center gap-2 mb-2">
                <span class="w-6 h-6 rounded-full bg-[#2a2a3a] text-white flex items-center justify-center text-sm font-bold">3</span>
                <span class="text-white font-medium">Verify ownership</span>
              </div>
              <div class="mt-3">
                <button 
                  id="verify-check-btn"
                  class="px-4 py-2 bg-[#00f5d4] hover:bg-[#00d4b8] text-[#0a0a0f] font-bold rounded transition-colors disabled:opacity-50"
                >
                  <span id="verify-btn-text">Check MOTD</span>
                  <span id="verify-btn-spinner" class="hidden">⏳</span>
                </button>
                <p id="verify-status" class="text-[#8892b0] text-sm mt-2"></p>
                <div id="verify-attempts" class="text-[#8892b0] text-xs mt-1 hidden"></div>
              </div>
            </div>
          </div>

          <div id="verification-success" class="hidden mt-4 p-4 bg-green-500/10 border border-green-500/30 rounded-lg">
            <p class="text-green-400 font-medium">✓ Server ownership verified!</p>
            <p class="text-[#8892b0] text-sm mt-1">You can now manage your server.</p>
            <button id="go-to-dashboard-btn" class="mt-3 px-4 py-2 bg-green-500/20 hover:bg-green-500/30 text-green-400 rounded transition-colors">
              Go to Dashboard
            </button>
          </div>
        </div>
      </div>

      <!-- Dashboard Content (shown when logged in) -->
      <div id="dashboard-content" class="hidden">
        <!-- Server Selector -->
        <div class="mb-6">
          <label class="text-[#8892b0] text-sm mb-2 block">Select Server</label>
          <select 
            id="server-selector"
            class="w-full px-4 py-3 bg-[#0a0a0f] border border-[#2a2a3a] rounded-lg text-white focus:outline-none focus:border-[#00f5d4]"
          >
            <option value="">Loading your servers...</option>
          </select>
        </div>

        <!-- Tab Navigation -->
        <div class="border-b border-[#2a2a3a] mb-6">
          <nav class="flex gap-6">
            <button data-tab="overview" class="tab-btn px-4 py-3 text-white border-b-2 border-[#00f5d4] font-medium">
              Overview
            </button>
            <button data-tab="analytics" class="tab-btn px-4 py-3 text-[#8892b0] hover:text-white border-b-2 border-transparent transition-colors">
              Analytics
            </button>
            <button data-tab="edit" class="tab-btn px-4 py-3 text-[#8892b0] hover:text-white border-b-2 border-transparent transition-colors">
              Edit
            </button>
            <button data-tab="votes" class="tab-btn px-4 py-3 text-[#8892b0] hover:text-white border-b-2 border-transparent transition-colors">
              Votes
            </button>
          </nav>
        </div>

        <!-- Tab Content: Overview -->
        <div id="tab-overview" class="tab-content">
          <!-- Stats Grid -->
          <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
            <div class="p-4 bg-[#12121a] border border-[#2a2a3a] rounded-lg">
              <div class="text-[#8892b0] text-sm mb-1">Total Votes</div>
              <div id="stat-votes" class="text-3xl font-black text-[#ff3864]">--</div>
              <div id="stat-votes-change" class="text-green-500 text-xs mt-1">↑ +0 today</div>
            </div>
            
            <div class="p-4 bg-[#12121a] border border-[#2a2a3a] rounded-lg">
              <div class="text-[#8892b0] text-sm mb-1">Players Online</div>
              <div id="stat-players" class="text-3xl font-black text-[#00f5d4]">--</div>
              <div id="stat-max-players" class="text-[#8892b0] text-xs mt-1">Max: --</div>
            </div>
            
            <div class="p-4 bg-[#12121a] border border-[#2a2a3a] rounded-lg">
              <div class="text-[#8892b0] text-sm mb-1">Uptime</div>
              <div id="stat-uptime" class="text-3xl font-black text-white">--%</div>
              <div class="text-[#8892b0] text-xs mt-1">Last 7 days</div>
            </div>
            
            <div class="p-4 bg-[#12121a] border border-[#2a2a3a] rounded-lg">
              <div class="text-[#8892b0] text-sm mb-1">Rank</div>
              <div id="stat-rank" class="text-3xl font-black text-white">#--</div>
              <div class="text-[#8892b0] text-xs mt-1">Overall</div>
            </div>
          </div>

          <!-- Quick Actions -->
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
            <button id="refresh-stats-btn" class="p-4 bg-[#12121a] border border-[#2a2a3a] rounded-lg hover:border-[#00f5d4] transition-colors text-left group">
              <div class="text-white font-medium group-hover:text-[#00f5d4]">🔄 Refresh Stats</div>
              <div class="text-[#8892b0] text-sm">Update server information</div>
            </button>
            <button id="copy-server-link-btn" class="p-4 bg-[#12121a] border border-[#2a2a3a] rounded-lg hover:border-[#00f5d4] transition-colors text-left group">
              <div class="text-white font-medium group-hover:text-[#00f5d4]">📋 Copy Link</div>
              <div class="text-[#8892b0] text-sm">Share your server page</div>
            </button>
            <button id="view-public-btn" class="p-4 bg-[#12121a] border border-[#2a2a3a] rounded-lg hover:border-[#00f5d4] transition-colors text-left group">
              <div class="text-white font-medium group-hover:text-[#00f5d4]">🔗 View Public Page</div>
              <div class="text-[#8892b0] text-sm">See how others see it</div>
            </button>
          </div>
        </div>

        <!-- Tab Content: Analytics -->
        <div id="tab-analytics" class="tab-content hidden">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
            <!-- Player History Chart -->
            <div class="p-6 bg-[#12121a] border border-[#2a2a3a] rounded-lg">
              <div class="flex items-center justify-between mb-4">
                <h3 class="text-lg font-bold text-white">Player History (24h)</h3>
                <div class="flex gap-2">
                  <button data-range="24h" class="range-btn px-2 py-1 text-xs bg-[#00f5d4]/20 text-[#00f5d4] rounded">24h</button>
                  <button data-range="7d" class="range-btn px-2 py-1 text-xs bg-[#2a2a3a] text-[#8892b0] rounded hover:text-white">7d</button>
                  <button data-range="30d" class="range-btn px-2 py-1 text-xs bg-[#2a2a3a] text-[#8892b0] rounded hover:text-white">30d</button>
                </div>
              </div>
              <div id="player-chart-container" class="h-64">
                <canvas id="player-chart"></canvas>
              </div>
              <div id="player-chart-loading" class="h-64 flex items-center justify-center">
                <div class="text-[#8892b0]">Loading chart...</div>
              </div>
            </div>
            
            <!-- Vote History Chart -->
            <div class="p-6 bg-[#12121a] border border-[#2a2a3a] rounded-lg">
              <h3 class="text-lg font-bold text-white mb-4">Vote History (7 days)</h3>
              <div id="vote-chart-container" class="h-64">
                <canvas id="vote-chart"></canvas>
              </div>
              <div id="vote-chart-loading" class="h-64 flex items-center justify-center hidden">
                <div class="text-[#8892b0]">Loading chart...</div>
              </div>
            </div>
            
            <!-- Uptime Gauge -->
            <div class="p-6 bg-[#12121a] border border-[#2a2a3a] rounded-lg">
              <h3 class="text-lg font-bold text-white mb-4">Uptime</h3>
              <div class="flex items-center justify-center h-48">
                <div class="relative w-40 h-40">
                  <canvas id="uptime-chart"></canvas>
                  <div class="absolute inset-0 flex items-center justify-center flex-col">
                    <span id="uptime-value" class="text-3xl font-black text-white">--%</span>
                    <span class="text-[#8892b0] text-xs">Uptime</span>
                  </div>
                </div>
              </div>
              <div class="text-center mt-4">
                <div class="text-[#8892b0] text-sm">
                  Avg Players: <span id="avg-players" class="text-white font-medium">--</span>
                  | Peak: <span id="peak-players" class="text-white font-medium">--</span>
                </div>
              </div>
            </div>
            
            <!-- Rank Trend -->
            <div class="p-6 bg-[#12121a] border border-[#2a2a3a] rounded-lg">
              <h3 class="text-lg font-bold text-white mb-4">Rank Trend</h3>
              <div id="rank-chart-container" class="h-48">
                <canvas id="rank-chart"></canvas>
              </div>
              <div id="rank-chart-loading" class="h-48 flex items-center justify-center hidden">
                <div class="text-[#8892b0]">Loading...</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Tab Content: Edit -->
        <div id="tab-edit" class="tab-content hidden">
          <div class="p-6 bg-[#12121a] border border-[#2a2a3a] rounded-lg mb-8">
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-lg font-bold text-white">Edit Server Details</h3>
              <div id="edit-status" class="text-sm hidden"></div>
            </div>
            
            <!-- Verification Required Warning -->
            <div id="edit-verification-required" class="hidden mb-4 p-4 bg-yellow-500/10 border border-yellow-500/30 rounded-lg">
              <p class="text-yellow-400 font-medium">⚠️ Verification Required</p>
              <p class="text-[#8892b0] text-sm mt-1">You need to verify server ownership before editing.</p>
              <button id="verify-now-btn" class="mt-2 px-4 py-2 bg-yellow-500/20 hover:bg-yellow-500/30 text-yellow-400 rounded text-sm transition-colors">
                Start Verification
              </button>
            </div>
            
            <form id="edit-form" class="space-y-4">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                  <label class="text-[#8892b0] text-sm mb-1 block">Server Name *</label>
                  <input 
                    type="text" 
                    id="edit-name"
                    required
                    minlength="2"
                    maxlength="100"
                    class="w-full px-4 py-3 bg-[#0a0a0f] border border-[#2a2a3a] rounded-lg text-white focus:outline-none focus:border-[#00f5d4] disabled:opacity-50"
                  >
                  <p class="text-[#8892b0] text-xs mt-1">2-100 characters</p>
                </div>
                
                <div>
                  <label class="text-[#8892b0] text-sm mb-1 block">Server IP</label>
                  <input 
                    type="text" 
                    id="edit-ip"
                    class="w-full px-4 py-3 bg-[#0a0a0f] border border-[#2a2a3a] rounded-lg text-white focus:outline-none disabled:opacity-50"
                    disabled
                  >
                  <p class="text-[#8892b0] text-xs mt-1">Contact support to change IP</p>
                </div>
                
                <div>
                  <label class="text-[#8892b0] text-sm mb-1 block">Website URL</label>
                  <input 
                    type="url" 
                    id="edit-website"
                    placeholder="https://"
                    class="w-full px-4 py-3 bg-[#0a0a0f] border border-[#2a2a3a] rounded-lg text-white focus:outline-none focus:border-[#00f5d4] disabled:opacity-50"
                  >
                </div>
                
                <div>
                  <label class="text-[#8892b0] text-sm mb-1 block">Discord Invite</label>
                  <input 
                    type="text" 
                    id="edit-discord"
                    placeholder="https://discord.gg/..."
                    class="w-full px-4 py-3 bg-[#0a0a0f] border border-[#2a2a3a] rounded-lg text-white focus:outline-none focus:border-[#00f5d4] disabled:opacity-50"
                  >
                </div>
              </div>
              
              <div>
                <label class="text-[#8892b0] text-sm mb-1 block">Description</label>
                <textarea 
                  id="edit-description"
                  rows="3"
                  maxlength="2000"
                  placeholder="Describe your server..."
                  class="w-full px-4 py-3 bg-[#0a0a0f] border border-[#2a2a3a] rounded-lg text-white focus:outline-none focus:border-[#00f5d4] resize-none disabled:opacity-50"
                ></textarea>
                <p class="text-[#8892b0] text-xs mt-1"><span id="desc-char-count">0</span>/2000 characters</p>
              </div>
              
              <div>
                <label class="text-[#8892b0] text-sm mb-1 block">Tags (comma-separated)</label>
                <input 
                  type="text" 
                  id="edit-tags"
                  placeholder="Survival, PvP, Economy"
                  class="w-full px-4 py-3 bg-[#0a0a0f] border border-[#2a2a3a] rounded-lg text-white focus:outline-none focus:border-[#00f5d4] disabled:opacity-50"
                >
              </div>
              
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                  <label class="text-[#8892b0] text-sm mb-1 block">Votifier Public Key</label>
                  <textarea 
                    id="edit-votifier-key"
                    rows="3"
                    placeholder="Paste your Votifier public key..."
                    class="w-full px-4 py-3 bg-[#0a0a0f] border border-[#2a2a3a] rounded-lg text-white focus:outline-none focus:border-[#00f5d4] font-mono text-xs resize-none disabled:opacity-50"
                  ></textarea>
                </div>
                
                <div>
                  <label class="text-[#8892b0] text-sm mb-1 block">Discord Webhook URL</label>
                  <input 
                    type="url" 
                    id="edit-webhook"
                    placeholder="https://discord.com/api/webhooks/..."
                    class="w-full px-4 py-3 bg-[#0a0a0f] border border-[#2a2a3a] rounded-lg text-white focus:outline-none focus:border-[#00f5d4] disabled:opacity-50"
                  >
                  <p class="text-[#8892b0] text-xs mt-1">For vote notifications</p>
                </div>
              </div>
              
              <div class="flex items-center gap-4 pt-4">
                <button 
                  type="submit"
                  id="save-changes-btn"
                  class="px-6 py-3 bg-[#00f5d4] hover:bg-[#00d4b8] text-[#0a0a0f] font-bold rounded-lg transition-colors disabled:opacity-50"
                >
                  <span id="save-btn-text">Save Changes</span>
                  <span id="save-btn-spinner" class="hidden">⏳</span>
                </button>
                <button 
                  type="button"
                  id="cancel-edit-btn"
                  class="px-6 py-3 bg-[#1a1a25] hover:bg-[#2a2a3a] text-white rounded-lg transition-colors"
                >
                  Cancel
                </button>
                <span id="rate-limit-info" class="text-[#8892b0] text-sm hidden"></span>
              </div>
            </form>
          </div>

          <!-- Audit Log -->
          <div class="p-6 bg-[#12121a] border border-[#2a2a3a] rounded-lg">
            <h3 class="text-lg font-bold text-white mb-4">Recent Changes</h3>
            <div id="audit-log" class="space-y-2 max-h-64 overflow-y-auto">
              <p class="text-[#8892b0] text-sm">No recent changes</p>
            </div>
          </div>
        </div>

        <!-- Tab Content: Votes -->
        <div id="tab-votes" class="tab-content hidden">
          <div class="p-6 bg-[#12121a] border border-[#2a2a3a] rounded-lg">
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-lg font-bold text-white">Recent Votes</h3>
              <button id="refresh-votes-btn" class="text-sm text-[#00f5d4] hover:underline">
                Refresh
              </button>
            </div>
            
            <div class="overflow-x-auto">
              <table class="w-full">
                <thead>
                  <tr class="text-[#8892b0] text-left text-sm border-b border-[#2a2a3a]">
                    <th class="pb-3 font-medium">Player</th>
                    <th class="pb-3 font-medium">Time</th>
                    <th class="pb-3 font-medium">Country</th>
                    <th class="pb-3 font-medium">Status</th>
                  </tr>
                </thead>
                <tbody id="votes-table">
                  <tr>
                    <td colspan="4" class="text-[#8892b0] text-center py-8">Loading votes...</td>
                  </tr>
                </tbody>
              </table>
            </div>
            
            <!-- Pagination -->
            <div id="votes-pagination" class="flex items-center justify-between mt-4 pt-4 border-t border-[#2a2a3a] hidden">
              <span id="votes-count" class="text-[#8892b0] text-sm">Showing 0 votes</span>
              <div class="flex gap-2">
                <button id="votes-prev" class="px-3 py-1 bg-[#2a2a3a] text-white rounded hover:bg-[#3a3a4a] disabled:opacity-50">Previous</button>
                <button id="votes-next" class="px-3 py-1 bg-[#2a2a3a] text-white rounded hover:bg-[#3a3a4a] disabled:opacity-50">Next</button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>

    <!-- Toast Container -->
    <div id="toast-container" class="fixed bottom-4 right-4 z-50 space-y-2"></div>

    <Footer />
  </div>
</Layout>

<script>
  import { createClient } from '@supabase/supabase-js';
  import Chart from 'chart.js/auto';
  
  const supabaseUrl = 'https://wpxutsdbiampnxfgkjwq.supabase.co';
  const supabaseKey = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6IndweHV0c2RiaWFtcG54ZmdrandxIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzUzNTEwMDQsImV4cCI6MjA5MDkyNzAwNH0.35hrTSgxQnICpLOY3g6W3eNxxe7DKCc3q165tyb0Ieo';
  
  const supabase = createClient(supabaseUrl, supabaseKey);
  
  // State
  let ownedServers: string[] = [];
  let selectedServer: string | null = null;
  let currentVerification: any = null;
  let charts: { [key: string]: Chart | null } = {};
  let currentTab = 'overview';
  let analyticsRange = '24h';
  let isVerified = false;
  let currentOwnerEmail = '';
  
  // Chart.js default config for dark theme
  Chart.defaults.color = '#8892b0';
  Chart.defaults.borderColor = '#2a2a3a';
  
  // Load owned servers from localStorage
  function loadOwnedServers() {
    const stored = localStorage.getItem('guildpost_owned_servers');
    const storedEmail = localStorage.getItem('guildpost_owner_email');
    if (storedEmail) {
      currentOwnerEmail = storedEmail;
    }
    
    if (stored) {
      try {
        const parsed = JSON.parse(stored);
        ownedServers = Array.isArray(parsed) ? parsed : [];
        if (ownedServers.length > 0) {
          showDashboard();
          populateServerSelector();
          selectServer(ownedServers[0]);
        }
      } catch (e) {
        console.error('Failed to parse owned servers:', e);
        ownedServers = [];
      }
    }
  }
  
  function showDashboard() {
    document.getElementById('auth-section')?.classList.add('hidden');
    document.getElementById('verification-section')?.classList.add('hidden');
    document.getElementById('dashboard-content')?.classList.remove('hidden');
  }
  
  function showAuth() {
    document.getElementById('auth-section')?.classList.remove('hidden');
    document.getElementById('verification-section')?.classList.add('hidden');
    document.getElementById('dashboard-content')?.classList.add('hidden');
  }
  
  function showVerification() {
    document.getElementById('auth-section')?.classList.add('hidden');
    document.getElementById('verification-section')?.classList.remove('hidden');
    document.getElementById('dashboard-content')?.classList.add('hidden');
  }
  
  function populateServerSelector() {
    const selector = document.getElementById('server-selector') as HTMLSelectElement;
    if (!selector || ownedServers.length === 0) return;
    
    selector.innerHTML = ownedServers.map(id => 
      `<option value="${id}">${id}</option>`
    ).join('');
    
    selector.addEventListener('change', (e) => {
      const target = e.target as HTMLSelectElement;
      selectServer(target.value);
    });
  }
  
  async function selectServer(serverId: string) {
    selectedServer = serverId;
    
    // Load server data
    const { data: server, error } = await supabase
      .from('servers')
      .select('*')
      .eq('id', serverId)
      .single();
    
    if (error || !server) {
      showToast('Server not found', 'error');
      return;
    }
    
    // Check verification status
    isVerified = !!server.verified_owner;
    
    // Update stats
    document.getElementById('stat-votes')!.textContent = (server.vote_count || 0).toLocaleString();
    document.getElementById('stat-players')!.textContent = (server.players_online || 0).toLocaleString();
    document.getElementById('stat-max-players')!.textContent = `Max: ${server.max_players || '?'}`;
    
    // Calculate rank (approximate)
    const { count } = await supabase
      .from('servers')
      .select('*', { count: 'exact', head: true })
      .gt('vote_count', server.vote_count || 0);
    
    document.getElementById('stat-rank')!.textContent = `#${(count || 0) + 1}`;
    
    // Load uptime from ping history
    const { data: pings } = await supabase
      .from('server_ping_history')
      .select('status')
      .eq('server_id', serverId)
      .gte('created_at', new Date(Date.now() - 7 * 24 * 60 * 60 * 1000).toISOString());
    
    if (pings && pings.length > 0) {
      const onlineCount = pings.filter(p => p.status === 'online').length;
      const uptime = Math.round((onlineCount / pings.length) * 100);
      document.getElementById('stat-uptime')!.textContent = `${uptime}%`;
    } else {
      document.getElementById('stat-uptime')!.textContent = '--%';
    }
    
    // Populate edit form
    const editForm = document.getElementById('edit-form') as HTMLFormElement;
    if (editForm) {
      (document.getElementById('edit-name') as HTMLInputElement).value = server.name || '';
      (document.getElementById('edit-ip') as HTMLInputElement).value = `${server.ip}:${server.port}`;
      (document.getElementById('edit-website') as HTMLInputElement).value = server.website || '';
      (document.getElementById('edit-discord') as HTMLInputElement).value = server.discord || '';
      (document.getElementById('edit-description') as HTMLTextAreaElement).value = server.description || '';
      (document.getElementById('edit-tags') as HTMLInputElement).value = (server.tags || []).join(', ');
      (document.getElementById('edit-votifier-key') as HTMLTextAreaElement).value = server.votifier_key || '';
      (document.getElementById('edit-webhook') as HTMLInputElement).value = server.discord_webhook || '';
      updateCharCount();
    }
    
    // Show/hide verification required message
    const verificationWarning = document.getElementById('edit-verification-required');
    if (verificationWarning) {
      if (isVerified) {
        verificationWarning.classList.add('hidden');
        enableEditForm(true);
      } else {
        verificationWarning.classList.remove('hidden');
        enableEditForm(false);
      }
    }
    
    // Load votes
    loadVoteHistory(serverId);
    
    // Load analytics if on analytics tab
    if (currentTab === 'analytics') {
      loadAnalytics(serverId);
    }
  }
  
  function enableEditForm(enabled: boolean) {
    const inputs = document.querySelectorAll('#edit-form input:not(#edit-ip), #edit-form textarea');
    inputs.forEach(input => {
      (input as HTMLInputElement).disabled = !enabled;
    });
    (document.getElementById('save-changes-btn') as HTMLButtonElement).disabled = !enabled;
  }
  
  function updateCharCount() {
    const textarea = document.getElementById('edit-description') as HTMLTextAreaElement;
    const count = textarea?.value.length || 0;
    document.getElementById('desc-char-count')!.textContent = count.toString();
  }
  
  async function loadVoteHistory(serverId: string, page = 0) {
    const limit = 20;
    const offset = page * limit;
    
    const { data: votes, error, count } = await supabase
      .from('votes')
      .select('*', { count: 'exact' })
      .eq('server_id', serverId)
      .order('created_at', { ascending: false })
      .range(offset, offset + limit - 1);
    
    const table = document.getElementById('votes-table');
    if (!table) return;
    
    if (error) {
      table.innerHTML = '<tr><td colspan="4" class="text-[#ff3864] text-center py-8">Error loading votes</td></tr>';
      return;
    }
    
    if (!votes || votes.length === 0) {
      table.innerHTML = '<tr><td colspan="4" class="text-[#8892b0] text-center py-8">No votes yet</td></tr>';
      document.getElementById('votes-pagination')?.classList.add('hidden');
      return;
    }
    
    table.innerHTML = votes.map(vote => `
      <tr class="border-t border-[#2a2a3a]">
        <td class="py-3 text-white">${escapeHtml(vote.username)}</td>
        <td class="py-3 text-[#8892b0]">${new Date(vote.created_at).toLocaleString()}</td>
        <td class="py-3 text-[#8892b0]">${vote.country || '--'}</td>
        <td class="py-3">
          <span class="text-green-500">✓ Recorded</span>
        </td>
      </tr>
    `).join('');
    
    // Update pagination
    const pagination = document.getElementById('votes-pagination');
    const countEl = document.getElementById('votes-count');
    const prevBtn = document.getElementById('votes-prev') as HTMLButtonElement;
    const nextBtn = document.getElementById('votes-next') as HTMLButtonElement;
    
    if (pagination && count) {
      pagination.classList.remove('hidden');
      countEl!.textContent = `Showing ${offset + 1}-${Math.min(offset + votes.length, count)} of ${count} votes`;
      prevBtn.disabled = page === 0;
      nextBtn.disabled = offset + votes.length >= count;
      
      prevBtn.onclick = () => loadVoteHistory(serverId, page - 1);
      nextBtn.onclick = () => loadVoteHistory(serverId, page + 1);
    }
  }
  
  async function loadAnalytics(serverId: string) {
    try {
      // Show loading states
      document.getElementById('player-chart-loading')?.classList.remove('hidden');
      document.getElementById('player-chart-container')?.classList.add('hidden');
      
      const response = await fetch(`/api/servers/${encodeURIComponent(serverId)}/analytics?range=${analyticsRange}`);
      if (!response.ok) throw new Error('Failed to load analytics');
      
      const data = await response.json();
      
      // Hide loading, show charts
      document.getElementById('player-chart-loading')?.classList.add('hidden');
      document.getElementById('player-chart-container')?.classList.remove('hidden');
      document.getElementById('vote-chart-loading')?.classList.add('hidden');
      document.getElementById('rank-chart-loading')?.classList.add('hidden');
      
      // Update summary stats
      document.getElementById('stat-uptime')!.textContent = `${data.summary.uptime_percentage}%`;
      document.getElementById('uptime-value')!.textContent = `${data.summary.uptime_percentage}%`;
      document.getElementById('avg-players')!.textContent = data.summary.avg_players.toString();
      document.getElementById('peak-players')!.textContent = data.summary.peak_players.toString();
      
      // Render charts
      renderPlayerChart(data.charts.player_history);
      renderVoteChart(data.charts.vote_history);
      renderUptimeGauge(data.summary.uptime_percentage);
      renderRankChart(data.charts.rank_trend);
      
    } catch (err) {
      console.error('Failed to load analytics:', err);
      showToast('Failed to load analytics', 'error');
    }
  }
  
  function renderPlayerChart(chartData: any) {
    const ctx = (document.getElementById('player-chart') as HTMLCanvasElement)?.getContext('2d');
    if (!ctx) return;
    
    if (charts.player) {
      charts.player.destroy();
    }
    
    const gradient = ctx.createLinearGradient(0, 0, 0, 256);
    gradient.addColorStop(0, 'rgba(0, 245, 212, 0.3)');
    gradient.addColorStop(1, 'rgba(0, 245, 212, 0)');
    
    charts.player = new Chart(ctx, {
      type: 'line',
      data: {
        labels: chartData.labels,
        datasets: [{
          label: 'Players Online',
          data: chartData.data,
          borderColor: '#00f5d4',
          backgroundColor: gradient,
          fill: true,
          tension: 0.4,
          pointRadius: 0,
          pointHoverRadius: 4
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false }
        },
        scales: {
          x: { 
            grid: { display: false },
            ticks: { maxTicksLimit: 8 }
          },
          y: { 
            beginAtZero: true,
            grid: { color: '#2a2a3a' }
          }
        }
      }
    });
  }
  
  function renderVoteChart(chartData: any) {
    const ctx = (document.getElementById('vote-chart') as HTMLCanvasElement)?.getContext('2d');
    if (!ctx) return;
    
    if (charts.vote) {
      charts.vote.destroy();
    }
    
    charts.vote = new Chart(ctx, {
      type: 'bar',
      data: {
        labels: chartData.labels,
        datasets: [{
          label: 'Votes',
          data: chartData.data,
          backgroundColor: '#ff3864',
          borderRadius: 4
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false }
        },
        scales: {
          x: { 
            grid: { display: false }
          },
          y: { 
            beginAtZero: true,
            grid: { color: '#2a2a3a' },
            ticks: { stepSize: 1 }
          }
        }
      }
    });
  }
  
  function renderUptimeGauge(percentage: number) {
    const ctx = (document.getElementById('uptime-chart') as HTMLCanvasElement)?.getContext('2d');
    if (!ctx) return;
    
    if (charts.uptime) {
      charts.uptime.destroy();
    }
    
    charts.uptime = new Chart(ctx, {
      type: 'doughnut',
      data: {
        datasets: [{
          data: [percentage, 100 - percentage],
          backgroundColor: [
            percentage > 90 ? '#00f5d4' : percentage > 70 ? '#ffc107' : '#ff3864',
            '#2a2a3a'
          ],
          borderWidth: 0,
          cutout: '75%'
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        rotation: -90,
        circumference: 180
      }
    });
  }
  
  function renderRankChart(chartData: any) {
    const ctx = (document.getElementById('rank-chart') as HTMLCanvasElement)?.getContext('2d');
    if (!ctx || chartData.data.length === 0) return;
    
    if (charts.rank) {
      charts.rank.destroy();
    }
    
    charts.rank = new Chart(ctx, {
      type: 'line',
      data: {
        labels: chartData.labels,
        datasets: [{
          label: 'Rank',
          data: chartData.data,
          borderColor: '#ff3864',
          backgroundColor: 'rgba(255, 56, 100, 0.1)',
          fill: true,
          tension: 0.4,
          pointRadius: 3
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false }
        },
        scales: {
          x: { 
            grid: { display: false },
            ticks: { maxTicksLimit: 6 }
          },
          y: { 
            reverse: true, // Lower rank is better
            grid: { color: '#2a2a3a' },
            ticks: { stepSize: 10 }
          }
        }
      }
    });
  }
  
  // Tab switching
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const tab = (btn as HTMLElement).dataset.tab;
      if (!tab) return;
      
      // Update active tab
      document.querySelectorAll('.tab-btn').forEach(b => {
        b.classList.remove('text-white', 'border-[#00f5d4]');
        b.classList.add('text-[#8892b0]', 'border-transparent');
      });
      btn.classList.remove('text-[#8892b0]', 'border-transparent');
      btn.classList.add('text-white', 'border-[#00f5d4]');
      
      // Show tab content
      document.querySelectorAll('.tab-content').forEach(content => {
        content.classList.add('hidden');
      });
      document.getElementById(`tab-${tab}`)?.classList.remove('hidden');
      
      currentTab = tab;
      
      // Load analytics if switching to analytics tab
      if (tab === 'analytics' && selectedServer) {
        loadAnalytics(selectedServer);
      }
    });
  });
  
  // Range buttons
  document.querySelectorAll('.range-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const range = (btn as HTMLElement).dataset.range;
      if (!range) return;
      
      analyticsRange = range;
      
      // Update button styles
      document.querySelectorAll('.range-btn').forEach(b => {
        b.classList.remove('bg-[#00f5d4]/20', 'text-[#00f5d4]');
        b.classList.add('bg-[#2a2a3a]', 'text-[#8892b0]');
      });
      btn.classList.remove('bg-[#2a2a3a]', 'text-[#8892b0]');
      btn.classList.add('bg-[#00f5d4]/20', 'text-[#00f5d4]');
      
      // Reload analytics
      if (selectedServer) {
        loadAnalytics(selectedServer);
      }
    });
  });
  
  // Claim server - start verification
  document.getElementById('claim-server-btn')?.addEventListener('click', async () => {
    const serverId = (document.getElementById('server-id-input') as HTMLInputElement)?.value.trim();
    const ownerEmail = (document.getElementById('owner-email-input') as HTMLInputElement)?.value.trim();
    
    if (!serverId) {
      showToast('Please enter a server ID', 'warning');
      return;
    }
    
    const btn = document.getElementById('claim-server-btn') as HTMLButtonElement;
    const btnText = document.getElementById('claim-btn-text');
    const btnSpinner = document.getElementById('claim-btn-spinner');
    
    btn.disabled = true;
    btnText?.classList.add('hidden');
    btnSpinner?.classList.remove('hidden');
    
    try {
      const response = await fetch('/api/servers/verify', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ server_id: serverId, owner_email: ownerEmail })
      });
      
      const data = await response.json();
      
      if (!response.ok) {
        throw new Error(data.error || 'Failed to start verification');
      }
      
      // Store verification data
      currentVerification = data;
      
      // Show verification steps
      showVerification();
      document.getElementById('verification-token')!.textContent = data.verification_token;
      
      // Store owner email
      if (ownerEmail) {
        currentOwnerEmail = ownerEmail;
        localStorage.setItem('guildpost_owner_email', ownerEmail);
      }
      
      showToast('Verification started! Follow the steps below.', 'success');
      
    } catch (err: any) {
      showToast(err.message || 'Failed to start verification', 'error');
    } finally {
      btn.disabled = false;
      btnText?.classList.remove('hidden');
      btnSpinner?.classList.add('hidden');
    }
  });
  
  // Copy token
  document.getElementById('copy-token-btn')?.addEventListener('click', () => {
    if (currentVerification?.verification_token) {
      navigator.clipboard.writeText(currentVerification.verification_token);
      showToast('Token copied!', 'success');
    }
  });
  
  // Check MOTD for verification
  document.getElementById('verify-check-btn')?.addEventListener('click', async () => {
    if (!currentVerification) return;
    
    const btn = document.getElementById('verify-check-btn') as HTMLButtonElement;
    const btnText = document.getElementById('verify-btn-text');
    const btnSpinner = document.getElementById('verify-btn-spinner');
    const statusEl = document.getElementById('verify-status');
    const attemptsEl = document.getElementById('verify-attempts');
    
    btn.disabled = true;
    btnText?.classList.add('hidden');
    btnSpinner?.classList.remove('hidden');
    
    try {
      const response = await fetch(
        `/api/servers/${encodeURIComponent(currentVerification.server_id)}/verify-check?verification_id=${currentVerification.verification_id}`
      );
      
      const data = await response.json();
      
      if (data.verified) {
        // Verification successful!
        document.getElementById('verification-steps')?.classList.add('hidden');
        document.getElementById('verification-success')?.classList.remove('hidden');
        
        // Add to owned servers
        if (!ownedServers.includes(currentVerification.server_id)) {
          ownedServers.push(currentVerification.server_id);
          localStorage.setItem('guildpost_owned_servers', JSON.stringify(ownedServers));
        }
        
        showToast('Server verified successfully!', 'success');
      } else {
        // Not verified yet
        statusEl!.textContent = data.message || 'Token not found in MOTD. Make sure your server is online and the token is in the MOTD.';
        statusEl!.className = 'text-yellow-500 text-sm mt-2';
        
        if (data.attempts !== undefined) {
          attemptsEl!.textContent = `Attempt ${data.attempts}/10`;
          attemptsEl!.classList.remove('hidden');
        }
        
        if (data.current_motd) {
          console.log('Current MOTD:', data.current_motd);
        }
      }
      
    } catch (err: any) {
      statusEl!.textContent = 'Failed to check verification. Please try again.';
      statusEl!.className = 'text-red-500 text-sm mt-2';
    } finally {
      btn.disabled = false;
      btnText?.classList.remove('hidden');
      btnSpinner?.classList.add('hidden');
    }
  });
  
  // Go to dashboard after verification
  document.getElementById('go-to-dashboard-btn')?.addEventListener('click', () => {
    showDashboard();
    populateServerSelector();
    if (currentVerification?.server_id) {
      selectServer(currentVerification.server_id);
    }
  });
  
  // Verify now button (from edit tab)
  document.getElementById('verify-now-btn')?.addEventListener('click', () => {
    if (selectedServer) {
      (document.getElementById('server-id-input') as HTMLInputElement).value = selectedServer;
      showAuth();
    }
  });
  
  // Save edits
  document.getElementById('edit-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    if (!selectedServer || !isVerified) {
      showToast('You must verify ownership before editing', 'error');
      return;
    }
    
    const btn = document.getElementById('save-changes-btn') as HTMLButtonElement;
    const btnText = document.getElementById('save-btn-text');
    const btnSpinner = document.getElementById('save-btn-spinner');
    const statusEl = document.getElementById('edit-status');
    
    btn.disabled = true;
    btnText?.classList.add('hidden');
    btnSpinner?.classList.remove('hidden');
    statusEl?.classList.remove('hidden');
    statusEl!.textContent = 'Saving...';
    statusEl!.className = 'text-[#8892b0] text-sm';
    
    try {
      const updates = {
        owner_email: currentOwnerEmail,
        name: (document.getElementById('edit-name') as HTMLInputElement).value,
        website: (document.getElementById('edit-website') as HTMLInputElement).value,
        description: (document.getElementById('edit-description') as HTMLTextAreaElement).value,
        tags: (document.getElementById('edit-tags') as HTMLInputElement).value.split(',').map(t => t.trim()).filter(Boolean),
        votifier_key: (document.getElementById('edit-votifier-key') as HTMLTextAreaElement).value,
        discord_webhook: (document.getElementById('edit-webhook') as HTMLInputElement).value
      };
      
      const response = await fetch(`/api/servers/${encodeURIComponent(selectedServer)}/edit`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(updates)
      });
      
      const data = await response.json();
      
      if (!response.ok) {
        throw new Error(data.error || 'Failed to save changes');
      }
      
      statusEl!.textContent = 'Saved!';
      statusEl!.className = 'text-green-500 text-sm';
      showToast('Changes saved successfully!', 'success');
      
      // Update rate limit info
      if (data.rate_limit) {
        const rateInfo = document.getElementById('rate-limit-info');
        if (rateInfo) {
          rateInfo.textContent = `${data.rate_limit.remaining} edits remaining`;
          rateInfo.classList.remove('hidden');
        }
      }
      
      // Refresh server data
      setTimeout(() => {
        selectServer(selectedServer);
        statusEl?.classList.add('hidden');
      }, 2000);
      
    } catch (err: any) {
      statusEl!.textContent = err.message || 'Failed to save';
      statusEl!.className = 'text-red-500 text-sm';
      showToast(err.message || 'Failed to save changes', 'error');
    } finally {
      btn.disabled = false;
      btnText?.classList.remove('hidden');
      btnSpinner?.classList.add('hidden');
    }
  });
  
  // Cancel edit
  document.getElementById('cancel-edit-btn')?.addEventListener('click', () => {
    if (selectedServer) {
      selectServer(selectedServer);
    }
  });
  
  // Character count for description
  document.getElementById('edit-description')?.addEventListener('input', updateCharCount);
  
  // Quick action buttons
  document.getElementById('refresh-stats-btn')?.addEventListener('click', () => {
    if (selectedServer) {
      selectServer(selectedServer);
      showToast('Stats refreshed', 'success');
    }
  });
  
  document.getElementById('copy-server-link-btn')?.addEventListener('click', () => {
    if (selectedServer) {
      const url = `https://guildpost.tech/minecraft/${encodeURIComponent(selectedServer)}`;
      navigator.clipboard.writeText(url);
      showToast('Server link copied!', 'success');
    }
  });
  
  document.getElementById('view-public-btn')?.addEventListener('click', () => {
    if (selectedServer) {
      window.open(`/minecraft/${encodeURIComponent(selectedServer)}`, '_blank');
    }
  });
  
  document.getElementById('refresh-votes-btn')?.addEventListener('click', () => {
    if (selectedServer) {
      loadVoteHistory(selectedServer);
      showToast('Votes refreshed', 'success');
    }
  });
  
  // Toast notification
  function showToast(message: string, type: 'success' | 'error' | 'warning' = 'success') {
    const container = document.getElementById('toast-container');
    if (!container) return;
    
    const toast = document.createElement('div');
    const colors = {
      success: 'bg-green-500',
      error: 'bg-red-500',
      warning: 'bg-yellow-500'
    };
    
    toast.className = `${colors[type]} text-white px-4 py-3 rounded-lg shadow-lg transform transition-all duration-300 translate-x-full`;
    toast.textContent = message;
    
    container.appendChild(toast);
    
    // Animate in
    requestAnimationFrame(() => {
      toast.classList.remove('translate-x-full');
    });
    
    // Remove after 3 seconds
    setTimeout(() => {
      toast.classList.add('translate-x-full');
      setTimeout(() => toast.remove(), 300);
    }, 3000);
  }
  
  // Escape HTML to prevent XSS
  function escapeHtml(text: string): string {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }
  
  // Initialize
  loadOwnedServers();
</script>
