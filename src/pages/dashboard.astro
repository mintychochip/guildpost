---
// Server Owner Dashboard - Updated for Claims System
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ServerMediaUploader from '../components/ServerMediaUploader.astro';

// Get auth parameters from URL
const ownerEmail = Astro.url.searchParams.get('email');
const claimToken = Astro.url.searchParams.get('token');
const serverId = Astro.url.searchParams.get('server');

// Check authentication (email or valid token)
const isAuthenticated = !!ownerEmail || (!!claimToken && !!serverId);

// Server-side fetch claimed servers if authenticated
let ownedServers: any[] = [];
let authError = null;

if (isAuthenticated) {
  const supabaseUrl = 'https://wpxutsdbiampnxfgkjwq.supabase.co';
  const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY || '';
  
  try {
    let queryUrl = `${supabaseUrl}/rest/v1/servers?claimed=eq.true&select=id,name,ip,port,status,players_online,max_players,vote_count,avg_rating,review_count,description,website,tags,version,claimed,claimed_by,claimed_at,claim_verification_method,verified,created_at,uptime_stats,tier,stripe_customer_id,stripe_subscription_id,featured_until,premium_since`;
    
    if (ownerEmail) {
      queryUrl += `&claimed_by=eq.${encodeURIComponent(ownerEmail)}`;
    } else if (serverId && claimToken) {
      // Single server access via token - we'll verify client-side
      queryUrl += `&id=eq.${encodeURIComponent(serverId)}`;
    }
    
    queryUrl += '&order=claimed_at.desc';
    
    const response = await fetch(queryUrl, {
      headers: { 
        'apikey': supabaseKey, 
        'Authorization': `Bearer ${supabaseKey}` 
      }
    });
    
    if (response.ok) {
      ownedServers = await response.json();
    } else {
      authError = 'Failed to fetch your servers';
    }
  } catch (e) {
    authError = 'Error loading dashboard';
  }
}

const categories = [
  { id: 'tournament', name: 'Tournament', icon: '🏆' },
  { id: 'drop', name: 'Drop/Giveaway', icon: '🎁' },
  { id: 'update', name: 'Server Update', icon: '🚀' },
  { id: 'pvp', name: 'PvP Event', icon: '⚔️' },
  { id: 'building', name: 'Building Contest', icon: '🏗️' },
  { id: 'social', name: 'Social Event', icon: '🎉' },
  { id: 'other', name: 'Other', icon: '✨' },
];
---

<Layout 
  title="Server Owner Dashboard | GuildPost"
  description="Manage your Minecraft servers on GuildPost. View analytics, edit details, and track votes."
  url="https://guildpost.tech/dashboard"
>
  <div class="min-h-screen" style="background-color: var(--bg-primary);">
    <Header />
    
    <main class="max-w-6xl mx-auto px-4 py-8">
      {!isAuthenticated ? (
        <div class="max-w-md mx-auto mt-16">
          <h1 class="text-3xl font-black text-white mb-6 text-center">Server Owner Dashboard</h1>
          <div class="p-6 bg-[#12121a] border border-[#2a2a3a] rounded-lg space-y-4">
            <p class="text-[#8892b0]">Enter the email you used to claim your server:</p>
            <input 
              type="email" 
              id="login-email"
              placeholder="your@email.com"
              class="w-full px-4 py-3 bg-[#0a0a0f] border border-[#2a2a3a] rounded-lg text-white focus:border-[#00f5d4] focus:outline-none"
            />
            <button 
              id="login-btn"
              class="w-full px-4 py-3 bg-[#00f5d4] text-[#0a0a0f] font-bold rounded-lg hover:bg-[#00d4b8] transition-colors"
            >
              Access Dashboard
            </button>
            
            <div class="border-t border-[#2a2a3a] pt-4 mt-4">
              <p class="text-[#8892b0] text-sm mb-3">Don't have a claimed server yet?</p>
              <a 
                href="/claim"
                class="block w-full px-4 py-3 bg-[#8b5cf6]/20 text-[#8b5cf6] text-center rounded-lg hover:bg-[#8b5cf6]/30 transition-colors font-medium"
              >
                👑 Claim Your Server
              </a>
            </div>
          </div>
        </div>
      ) : (
        <div>
          <!-- Dashboard Header -->
          <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
            <div>
              <h1 class="text-3xl font-black text-white">Your Servers</h1>
              <p class="text-[#8892b0]">
                {ownerEmail ? `Managing as: ${ownerEmail}` : 'Server Owner Dashboard'}
              </p>
            </div>
            <div class="flex gap-2">
              <a 
                href="/submit"
                class="px-4 py-2 bg-[#1a1a25] text-white rounded-lg hover:bg-[#2a2a3a] transition-colors"
              >
                + Add Server
              </a>
              <a 
                href="/claim"
                class="px-4 py-2 bg-[#8b5cf6]/20 text-[#8b5cf6] rounded-lg hover:bg-[#8b5cf6]/30 transition-colors"
              >
                👑 Claim Another
              </a>
            </div>
          </div>
          
          {authError && (
            <div class="p-4 mb-6 bg-red-500/10 border border-red-500/30 rounded-lg">
              <p class="text-red-400">{authError}</p>
            </div>
          )}
          
          {ownedServers.length === 0 ? (
            <div class="p-12 bg-[#12121a] border border-[#2a2a3a] rounded-lg text-center">
              <div class="w-16 h-16 bg-[#8b5cf6]/20 rounded-full flex items-center justify-center mx-auto mb-4">
                <span class="text-[#8b5cf6] text-2xl">👑</span>
              </div>
              <p class="text-[#8892b0] text-lg mb-2">No claimed servers found</p>
              <p class="text-[#8892b0] text-sm mb-4">You haven't claimed any servers yet.</p>
              <a href="/claim" class="inline-block px-6 py-3 bg-[#00f5d4] text-[#0a0a0f] font-bold rounded-lg hover:bg-[#00d4b8] transition-colors">
                Claim Your First Server →
              </a>
            </div>
          ) : (
            <div class="space-y-6">
              {ownedServers.map(server => (
                <div class="p-6 bg-[#12121a] border border-[#2a2a3a] rounded-lg server-card" data-server-id={server.id}>
                  {/* Server Header */}
                  <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-6">
                    <div class="flex items-center gap-4">
                      <div class={`w-4 h-4 rounded-full ${server.status === 'online' ? 'bg-green-500' : 'bg-gray-500'}`}></div>
                      <div>
                        <div class="flex items-center gap-2 flex-wrap">
                          <h2 class="text-xl font-bold text-white">{server.name}</h2>
                          <span class="px-2 py-0.5 bg-[#8b5cf6]/20 text-[#8b5cf6] text-xs font-bold rounded">
                            👑 CLAIMED
                          </span>
                          {server.verified && (
                            <span class="px-2 py-0.5 bg-[#00f5d4]/20 text-[#00f5d4] text-xs font-bold rounded">
                              ✓ VERIFIED
                            </span>
                          )}
                          {server.tier === 'elite' && (
                            <span class="px-2 py-0.5 bg-gradient-to-r from-[#ff3864] to-[#a855f7] text-white text-xs font-bold rounded">
                              ⭐ ELITE
                            </span>
                          )}
                          {server.tier === 'premium' && (
                            <span class="px-2 py-0.5 bg-gradient-to-r from-[#ffd700] to-[#ffaa00] text-[#0a0a0f] text-xs font-bold rounded">
                              💎 PREMIUM
                            </span>
                          )}
                          {(!server.tier || server.tier === 'free') && (
                            <span class="px-2 py-0.5 bg-[#2a2a3a] text-[#8892b0] text-xs font-bold rounded">
                              FREE
                            </span>
                          )}
                        </div>
                        <p class="text-[#8892b0] text-sm">{server.ip}:{server.port}</p>
                      </div>
                    </div>
                    <div class="flex gap-2 flex-wrap">
                      {(!server.tier || server.tier === 'free') ? (
                        <a 
                          href={`/premium?server=${server.id}`}
                          class="px-4 py-2 bg-gradient-to-r from-[#ffd700] to-[#ffaa00] text-[#0a0a0f] rounded-lg hover:opacity-90 transition-opacity text-sm font-bold"
                        >
                          ⬆️ Upgrade
                        </a>
                      ) : (
                        <a 
                          href={`/premium?server=${server.id}`}
                          class="px-4 py-2 bg-[#1a1a25] text-[#00f5d4] border border-[#00f5d4]/30 rounded-lg hover:bg-[#00f5d4]/10 transition-colors text-sm"
                        >
                          Manage Plan
                        </a>
                      )}
                      <a 
                        href={`/servers/${server.id}`}
                        class="px-4 py-2 bg-[#1a1a25] text-[#8892b0] rounded-lg hover:bg-[#2a2a3a] transition-colors text-sm"
                      >
                        View Listing
                      </a>
                      <button 
                        class="px-4 py-2 bg-[#00f5d4] text-[#0a0a0f] rounded-lg hover:bg-[#00d4b8] transition-colors text-sm font-medium edit-server-btn"
                        data-server-id={server.id}
                      >
                        Edit Details
                      </button>
                    </div>
                  </div>
                  
                  {/* Quick Stats */}
                  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
                    <div class="p-3 bg-[#0a0a0f] rounded-lg text-center">
                      <p class="text-xl font-bold text-[#00f5d4]">{server.players_online || 0}</p>
                      <p class="text-xs text-[#8892b0]">Players Online</p>
                    </div>
                    <div class="p-3 bg-[#0a0a0f] rounded-lg text-center">
                      <p class="text-xl font-bold text-[#ff3864]">{server.vote_count || 0}</p>
                      <p class="text-xs text-[#8892b0]">Total Votes</p>
                    </div>
                    <div class="p-3 bg-[#0a0a0f] rounded-lg text-center">
                      <p class="text-xl font-bold text-white">{server.uptime_stats?.uptime_percentage || 'N/A'}{server.uptime_stats?.uptime_percentage ? '%' : ''}</p>
                      <p class="text-xs text-[#8892b0]">Uptime (24h)</p>
                    </div>
                    <div class="p-3 bg-[#0a0a0f] rounded-lg text-center">
                      <p class="text-xl font-bold text-yellow-500">{server.avg_rating || 'N/A'}</p>
                      <p class="text-xs text-[#8892b0]">Rating ({server.review_count || 0})</p>
                    </div>
                  </div>
                  
                  {/* Management Tabs */}
                  <div class="border-t border-[#2a2a3a] pt-4">
                    <div class="flex gap-2 mb-4 overflow-x-auto">
                      <button class="tab-btn px-4 py-2 bg-[#00f5d4] text-[#0a0a0f] rounded-lg text-sm font-medium" data-tab="overview" data-server={server.id}>
                        Overview
                      </button>
                      <button class="tab-btn px-4 py-2 bg-[#1a1a25] text-[#8892b0] rounded-lg text-sm hover:bg-[#2a2a3a] transition-colors" data-tab="analytics" data-server={server.id}>
                        Analytics
                      </button>
                      <button class="tab-btn px-4 py-2 bg-[#1a1a25] text-[#8892b0] rounded-lg text-sm hover:bg-[#2a2a3a] transition-colors" data-tab="posts" data-server={server.id}>
                        Posts
                      </button>
                      <button class="tab-btn px-4 py-2 bg-[#1a1a25] text-[#8892b0] rounded-lg text-sm hover:bg-[#2a2a3a] transition-colors" data-tab="settings" data-server={server.id}>
                        Settings
                      </button>
                    </div>
                    
                    {/* Overview Tab */}
                    <div id={`tab-overview-${server.id}`} class="tab-content">
                      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        {/* Quick Actions */}
                        <div class="p-4 bg-[#0a0a0f] rounded-lg">
                          <h3 class="font-bold text-white mb-3">Quick Actions</h3>
                          <div class="space-y-2">
                            <a 
                              href={`/api/servers/${server.id}/vote`}
                              class="block p-2 bg-[#1a1a25] hover:bg-[#2a2a3a] rounded text-sm text-white transition-colors"
                            >
                              🗳 Test Vote System
                            </a>
                            <button 
                              class="w-full p-2 bg-[#1a1a25] hover:bg-[#2a2a3a] rounded text-sm text-white transition-colors text-left refresh-server-btn"
                              data-server-id={server.id}
                            >
                              🔄 Refresh Server Data
                            </button>
                            <a 
                              href={`/banner-maker?server=${server.id}`}
                              class="block p-2 bg-[#1a1a25] hover:bg-[#2a2a3a] rounded text-sm text-white transition-colors"
                            >
                              🎨 Create Banner
                            </a>
                          </div>
                        </div>
                        
                        {/* Server Info */}
                        <div class="p-4 bg-[#0a0a0f] rounded-lg">
                          <h3 class="font-bold text-white mb-3">Server Info</h3>
                          <div class="space-y-2 text-sm">
                            <div class="flex justify-between">
                              <span class="text-[#8892b0]">Claimed:</span>
                              <span class="text-white">{server.claimed_at ? new Date(server.claimed_at).toLocaleDateString() : 'Unknown'}</span>
                            </div>
                            <div class="flex justify-between">
                              <span class="text-[#8892b0]">Verification:</span>
                              <span class="text-[#00f5d4]">{server.claim_verification_method || 'MOTD'}</span>
                            </div>
                            <div class="flex justify-between">
                              <span class="text-[#8892b0]">Listed:</span>
                              <span class="text-white">{server.created_at ? new Date(server.created_at).toLocaleDateString() : 'Unknown'}</span>
                            </div>
                            <div class="flex justify-between">
                              <span class="text-[#8892b0]">Server ID:</span>
                              <code class="text-[#00f5d4] font-mono text-xs">{server.id}</code>
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>
                    
                    {/* Analytics Tab */}
                    <div id={`tab-analytics-${server.id}`} class="tab-content hidden">
                      <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
                        {/* Vote Analytics */}
                        <div class="p-4 bg-[#0a0a0f] rounded-lg">
                          <div class="flex items-center justify-between mb-4">
                            <h3 class="font-bold text-white">Vote Analytics (24h)</h3>
                            <span id={`vote-trend-${server.id}`} class="text-xs"></span>
                          </div>
                          <div id={`vote-chart-${server.id}`} class="h-32 flex items-end gap-1">
                            <div class="col-span-full text-center text-[#8892b0] text-sm">Loading vote data...</div>
                          </div>
                          <div class="flex justify-between text-xs text-[#8892b0] mt-2">
                            <span>24h ago</span>
                            <span>Now</span>
                          </div>
                          <div id={`vote-stats-${server.id}`} class="mt-3 pt-3 border-t border-[#2a2a3a] text-xs text-[#8892b0]"></div>
                        </div>

                        {/* Player Analytics */}
                        <div class="p-4 bg-[#0a0a0f] rounded-lg">
                          <div class="flex items-center justify-between mb-4">
                            <h3 class="font-bold text-white">Player History (24h)</h3>
                            <span id={`player-trend-${server.id}`} class="text-xs"></span>
                          </div>
                          <div id={`player-chart-${server.id}`} class="h-32 flex items-end gap-1">
                            <div class="col-span-full text-center text-[#8892b0] text-sm">Loading player data...</div>
                          </div>
                          <div class="flex justify-between text-xs text-[#8892b0] mt-2">
                            <span>24h ago</span>
                            <span>Now</span>
                          </div>
                          <div id={`player-stats-${server.id}`} class="mt-3 pt-3 border-t border-[#2a2a3a] text-xs text-[#8892b0]"></div>
                        </div>
                      </div>
                    </div>
                    
                    {/* Posts Tab */}
                    <div id={`tab-posts-${server.id}`} class="tab-content hidden">
                      <div class="p-4 bg-[#0a0a0f] rounded-lg">
                        <h3 class="font-bold text-white mb-4">Create Server Post</h3>
                        <div class="space-y-3">
                          <select id={`post-category-${server.id}`} class="w-full px-3 py-2 bg-[#12121a] border border-[#2a2a3a] rounded text-white">
                            {categories.map(cat => (
                              <option value={cat.id}>{cat.icon} {cat.name}</option>
                            ))}
                          </select>
                          <input 
                            type="text" 
                            id={`post-title-${server.id}`}
                            placeholder="Post title..."
                            class="w-full px-3 py-2 bg-[#12121a] border border-[#2a2a3a] rounded text-white"
                          />
                          <textarea 
                            id={`post-content-${server.id}`}
                            placeholder="What's happening on your server?"
                            rows="3"
                            class="w-full px-3 py-2 bg-[#12121a] border border-[#2a2a3a] rounded text-white resize-none"
                          />
                          <button 
                            class="w-full px-4 py-2 bg-[#00f5d4] text-[#0a0a0f] font-bold rounded hover:bg-[#00d4b8] transition-colors create-post-btn"
                            data-server-id={server.id}
                          >
                            Publish Post
                          </button>
                        </div>
                      </div>
                    </div>
                    
                    {/* Settings Tab */}
                    <div id={`tab-settings-${server.id}`} class="tab-content hidden">
                      <div class="p-4 bg-[#0a0a0f] rounded-lg mb-6">
                        <h3 class="font-bold text-white mb-4">Server Media</h3>
                        <ServerMediaUploader serverId={server.id} />
                      </div>
                      
                      <div class="p-4 bg-[#0a0a0f] rounded-lg">
                        <h3 class="font-bold text-white mb-4">Server Settings</h3>
                        <div class="space-y-4">
                          <div>
                            <label class="block text-[#8892b0] text-sm mb-1">Server Description</label>
                            <textarea 
                              id={`settings-desc-${server.id}`}
                              rows="3"
                              class="w-full px-3 py-2 bg-[#12121a] border border-[#2a2a3a] rounded text-white resize-none"
                            >{server.description || ''}</textarea>
                          </div>
                          <div>
                            <label class="block text-[#8892b0] text-sm mb-1">Website URL</label>
                            <input 
                              type="url" 
                              id={`settings-website-${server.id}`}
                              value={server.website || ''}
                              placeholder="https://yourserver.com"
                              class="w-full px-3 py-2 bg-[#12121a] border border-[#2a2a3a] rounded text-white"
                            />
                          </div>
                          <div>
                            <label class="block text-[#8892b0] text-sm mb-1">Tags (comma separated)</label>
                            <input 
                              type="text" 
                              id={`settings-tags-${server.id}`}
                              value={server.tags?.join(', ') || ''}
                              placeholder="survival, pvp, economy"
                              class="w-full px-3 py-2 bg-[#12121a] border border-[#2a2a3a] rounded text-white"
                            />
                          </div>
                          <button 
                            class="w-full px-4 py-2 bg-[#00f5d4] text-[#0a0a0f] font-bold rounded hover:bg-[#00d4b8] transition-colors save-settings-btn"
                            data-server-id={server.id}
                          >
                            Save Changes
                          </button>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          )}
        </div>
      )}
    </main>
    
    <Footer />
  </div>
</Layout>

<script define:vars={{ ownerEmail, claimToken, serverId }}>
  // Store auth info in session for client-side access
  if (ownerEmail) {
    sessionStorage.setItem('dashboard_email', ownerEmail);
  }
  if (claimToken) {
    sessionStorage.setItem('dashboard_token', claimToken);
  }
  if (serverId) {
    sessionStorage.setItem('dashboard_server', serverId);
  }
  
  // Login button handler
  document.getElementById('login-btn')?.addEventListener('click', () => {
    const email = document.getElementById('login-email').value.trim();
    if (email && email.includes('@')) {
      window.location.href = `/dashboard?email=${encodeURIComponent(email)}`;
    } else {
      alert('Please enter a valid email address');
    }
  });
  
  // Tab switching
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const serverId = btn.dataset.server;
      const tabName = btn.dataset.tab;
      
      // Update button styles
      document.querySelectorAll(`.tab-btn[data-server="${serverId}"]`).forEach(b => {
        b.classList.remove('bg-[#00f5d4]', 'text-[#0a0a0f]');
        b.classList.add('bg-[#1a1a25]', 'text-[#8892b0]');
      });
      btn.classList.remove('bg-[#1a1a25]', 'text-[#8892b0]');
      btn.classList.add('bg-[#00f5d4]', 'text-[#0a0a0f]');
      
      // Show/hide content
      document.querySelectorAll(`.tab-content`).forEach(content => {
        content.classList.add('hidden');
      });
      document.getElementById(`tab-${tabName}-${serverId}`)?.classList.remove('hidden');
    });
  });
  
  // Edit server button
  document.querySelectorAll('.edit-server-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const serverId = btn.dataset.serverId;
      // Switch to settings tab
      document.querySelector(`.tab-btn[data-tab="settings"][data-server="${serverId}"]`)?.click();
    });
  });
  
  // Create post
  document.querySelectorAll('.create-post-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const serverId = btn.dataset.serverId;
      const category = document.getElementById(`post-category-${serverId}`).value;
      const title = document.getElementById(`post-title-${serverId}`).value;
      const content = document.getElementById(`post-content-${serverId}`).value;
      
      if (!title || !content) {
        alert('Please fill in both title and content');
        return;
      }
      
      btn.disabled = true;
      btn.innerHTML = '<span>Publishing...</span><span>⟳</span>';
      
      try {
        const response = await fetch(`/api/servers/${serverId}/posts`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            category,
            title,
            content,
            author: sessionStorage.getItem('dashboard_email') || 'Server Owner'
          })
        });
        
        if (response.ok) {
          alert('Post published successfully!');
          document.getElementById(`post-title-${serverId}`).value = '';
          document.getElementById(`post-content-${serverId}`).value = '';
        } else {
          throw new Error('Failed to publish post');
        }
      } catch (err) {
        alert('Error: ' + err.message);
      } finally {
        btn.disabled = false;
        btn.innerHTML = 'Publish Post';
      }
    });
  });
  
  // Save settings
  document.querySelectorAll('.save-settings-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const serverId = btn.dataset.serverId;
      const description = document.getElementById(`settings-desc-${serverId}`).value;
      const website = document.getElementById(`settings-website-${serverId}`).value;
      const tagsStr = document.getElementById(`settings-tags-${serverId}`).value;
      const tags = tagsStr.split(',').map(t => t.trim()).filter(t => t);
      
      btn.disabled = true;
      btn.innerHTML = '<span>Saving...</span><span>⟳</span>';
      
      try {
        const response = await fetch(`/api/servers/${serverId}/edit`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            description,
            website,
            tags,
            owner_email: sessionStorage.getItem('dashboard_email')
          })
        });
        
        if (response.ok) {
          alert('Settings saved successfully!');
        } else {
          throw new Error('Failed to save settings');
        }
      } catch (err) {
        alert('Error: ' + err.message);
      } finally {
        btn.disabled = false;
        btn.innerHTML = 'Save Changes';
      }
    });
  });
  
  // Refresh server
  document.querySelectorAll('.refresh-server-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const serverId = btn.dataset.serverId;
      btn.innerHTML = '🔄 Refreshing...';
      
      try {
        // Trigger a ping
        await fetch(`/api/ping?host=${btn.closest('.server-card').querySelector('p.text-\\[\\#8892b0\\]').textContent.split(':')[0]}`, { method: 'POST' });
        alert('Server data refreshed!');
        location.reload();
      } catch (err) {
        alert('Failed to refresh. Please try again.');
      } finally {
        btn.innerHTML = '🔄 Refresh Server Data';
      }
    });
  });
  
  // Handle enter key on email input
  document.getElementById('login-email')?.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') {
      document.getElementById('login-btn')?.click();
    }
  });

  // Load analytics data when analytics tab is clicked
  document.querySelectorAll('.tab-btn[data-tab="analytics"]').forEach(btn => {
    btn.addEventListener('click', async () => {
      const serverId = btn.dataset.server;
      await loadAnalytics(serverId);
    });
  });

  async function loadAnalytics(serverId) {
    // Load vote analytics
    try {
      const voteResponse = await fetch(`/api/servers/${serverId}/votes?hours=24`);
      if (voteResponse.ok) {
        const voteData = await voteResponse.json();
        renderVoteChart(serverId, voteData);
      }
    } catch (err) {
      console.error('Failed to load vote analytics:', err);
    }

    // Load player analytics
    try {
      const playerResponse = await fetch(`/api/servers/${serverId}/players?hours=24`);
      if (playerResponse.ok) {
        const playerData = await playerResponse.json();
        renderPlayerChart(serverId, playerData);
      }
    } catch (err) {
      console.error('Failed to load player analytics:', err);
    }
  }

  function renderVoteChart(serverId, data) {
    const chartContainer = document.getElementById(`vote-chart-${serverId}`);
    const statsContainer = document.getElementById(`vote-stats-${serverId}`);
    const trendContainer = document.getElementById(`vote-trend-${serverId}`);

    if (!chartContainer || !data.chart_data) return;

    // Calculate max for scaling
    const maxVotes = Math.max(...data.chart_data.map(d => d.votes), 1);

    // Render bars
    chartContainer.innerHTML = data.chart_data.map((d, i) => {
      const height = maxVotes > 0 ? (d.votes / maxVotes) * 100 : 0;
      const hour = new Date(d.hour).getUTCHours();
      return `<div
        class="flex-1 bg-[#00f5d4]/40 hover:bg-[#00f5d4] transition-colors rounded-t cursor-pointer"
        style="height: ${Math.max(height, 5)}%"
        title="${hour}:00 UTC - ${d.votes} votes"
      />`;
    }).join('');

    // Render stats
    if (statsContainer) {
      statsContainer.innerHTML = `
        <span class="text-[#00f5d4]">${data.total_votes || 0} total votes</span> •
        <span>${data.avg_per_hour || 0}/hour avg</span> •
        <span>${data.max_per_hour || 0} peak</span>
      `;
    }

    // Render trend
    if (trendContainer && data.trend_percent !== undefined) {
      const trend = data.trend_percent;
      const trendColor = trend > 0 ? '#10b981' : trend < 0 ? '#ef4444' : '#8892b0';
      const trendIcon = trend > 0 ? '↗' : trend < 0 ? '↘' : '→';
      trendContainer.innerHTML = `<span style="color: ${trendColor}">${trendIcon} ${Math.abs(trend)}% vs last 24h</span>`;
    }
  }

  function renderPlayerChart(serverId, data) {
    const chartContainer = document.getElementById(`player-chart-${serverId}`);
    const statsContainer = document.getElementById(`player-stats-${serverId}`);
    const trendContainer = document.getElementById(`player-trend-${serverId}`);

    if (!chartContainer || !data.chart_data) return;

    // Calculate max for scaling
    const maxPlayers = Math.max(...data.chart_data.map(d => d.max_players), 1);

    // Render bars showing avg players (with max as hover)
    chartContainer.innerHTML = data.chart_data.map((d, i) => {
      const height = maxPlayers > 0 ? (d.avg_players / maxPlayers) * 100 : 0;
      const hour = new Date(d.hour).getUTCHours();
      return `<div
        class="flex-1 bg-[#a855f7]/40 hover:bg-[#a855f7] transition-colors rounded-t cursor-pointer"
        style="height: ${Math.max(height, 5)}%"
        title="${hour}:00 UTC - Avg: ${d.avg_players}, Max: ${d.max_players}, Min: ${d.min_players}"
      />`;
    }).join('');

    // Render stats
    if (statsContainer) {
      statsContainer.innerHTML = `
        <span class="text-[#a855f7]">${data.avg_players || 0} avg players</span> •
        <span>${data.max_players || 0} max</span> •
        <span>${data.min_players || 0} min</span> •
        <span>${data.total_samples || 0} samples</span>
      `;
    }

    // Render trend
    if (trendContainer && data.trend_percent !== undefined) {
      const trend = data.trend_percent;
      const trendColor = trend > 0 ? '#10b981' : trend < 0 ? '#ef4444' : '#8892b0';
      const trendIcon = trend > 0 ? '↗' : trend < 0 ? '↘' : '→';
      trendContainer.innerHTML = `<span style="color: ${trendColor}">${trendIcon} ${Math.abs(trend)}% vs last 24h</span>`;
    }
  }
</script>