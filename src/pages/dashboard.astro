---
// Server Owner Dashboard
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// Check for auth token in URL (temp solution until proper auth)
const authToken = Astro.url.searchParams.get('token');
const isAuthenticated = !!authToken; // Simplified - would check Supabase Auth

// Mock data for now - would fetch from API
const ownedServers = [
  { id: '1', name: 'Test Server', ip: 'play.example.com', port: 25565, vote_count: 42, players_online: 15, status: 'online' }
];
---

<Layout 
  title="Server Owner Dashboard | GuildPost"
  description="Manage your Minecraft servers on GuildPost. View analytics, edit details, and track votes."
  url="https://guildpost.tech/dashboard"
>
  <div class="min-h-screen bg-[#0a0a0f]">
    <Header />
    
    <main class="max-w-6xl mx-auto px-4 py-8">
      {!isAuthenticated ? (
        <div class="max-w-md mx-auto mt-16">
          <h1 class="text-3xl font-black text-white mb-6 text-center">Server Owner Login</h1>
          <div class="p-6 bg-[#12121a] border border-[#2a2a3a] rounded-lg">
            <p class="text-[#8892b0] mb-4">Enter your email to access your server dashboard.</p>
            <input 
              type="email" 
              id="login-email"
              placeholder="your@email.com"
              class="w-full px-4 py-3 bg-[#0a0a0f] border border-[#2a2a3a] rounded-lg text-white mb-4"
            />
            <button 
              id="login-btn"
              class="w-full px-4 py-3 bg-[#00f5d4] text-[#0a0a0f] font-bold rounded-lg hover:bg-[#00d4b8] transition-colors"
            >
              Send Magic Link
            </button>
            <p class="text-[#8892b0] text-xs mt-4 text-center">
              You'll receive a login link via email. No password needed.
            </p>
          </div>
        </div>
      ) : (
        <div>
          <div class="flex items-center justify-between mb-8">
            <div>
              <h1 class="text-3xl font-black text-white">Your Servers</h1>
              <p class="text-[#8892b0]">Manage your listings and view analytics</p>
            </div>
            <a 
              href="/submit"
              class="px-4 py-2 bg-[#00f5d4] text-[#0a0a0f] font-bold rounded-lg hover:bg-[#00d4b8] transition-colors"
            >
              + Add Server
            </a>
          </div>
          
          {ownedServers.length === 0 ? (
            <div class="p-12 bg-[#12121a] border border-[#2a2a3a] rounded-lg text-center">
              <p class="text-[#8892b0] text-lg mb-4">You don't have any servers yet.</p>
              <a href="/submit" class="text-[#00f5d4] hover:underline">
                Submit your first server →
              </a>
            </div>
          ) : (
            <div class="grid grid-cols-1 gap-4">
              {ownedServers.map(server => (
                <div class="p-6 bg-[#12121a] border border-[#2a2a3a] rounded-lg">
                  <div class="flex items-center justify-between mb-4">
                    <div class="flex items-center gap-4">
                      <div class={`w-3 h-3 rounded-full ${server.status === 'online' ? 'bg-green-500' : 'bg-gray-500'}`}></div>
                      <div>
                        <h2 class="text-xl font-bold text-white">{server.name}</h2>
                        <p class="text-[#8892b0] text-sm">{server.ip}:{server.port}</p>
                      </div>
                    </div>
                    <div class="flex gap-2">
                      <a 
                        href={`/servers/${server.id}`}
                        class="px-3 py-1.5 bg-[#1a1a25] text-[#8892b0] rounded hover:bg-[#2a2a3a] transition-colors text-sm"
                      >
                        View
                      </a>
                      <button 
                        class="px-3 py-1.5 bg-[#1a1a25] text-[#8892b0] rounded hover:bg-[#2a2a3a] transition-colors text-sm edit-server-btn"
                        data-server-id={server.id}
                      >
                        Edit
                      </button>
                    </div>
                  </div>
                  
                  <div class="grid grid-cols-3 gap-4 mb-4">
                    <div class="p-3 bg-[#0a0a0f] rounded text-center">
                      <p class="text-2xl font-bold text-[#ff3864]">{server.vote_count}</p>
                      <p class="text-[#8892b0] text-xs">Total Votes</p>
                    </div>
                    <div class="p-3 bg-[#0a0a0f] rounded text-center">
                      <p class="text-2xl font-bold text-white">{server.players_online}</p>
                      <p class="text-[#8892b0] text-xs">Players Online</p>
                    </div>
                    <div class="p-3 bg-[#0a0a0f] rounded text-center">
                      <p class="text-2xl font-bold text-[#00f5d4]">--</p>
                      <p class="text-[#8892b0] text-xs">Uptime %</p>
                    </div>
                  </div>
                  
                  <!-- Vote Chart Placeholder -->
                  <div class="p-4 bg-[#0a0a0f] rounded">
                    <h3 class="text-sm font-bold text-[#8892b0] mb-2">Votes (Last 30 Days)</h3>
                    <div class="h-24 bg-[#1a1a25] rounded flex items-center justify-center">
                      <p class="text-[#8892b0] text-sm">📊 Vote chart coming soon</p>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          )}
        </div>
      )}
    </main>
    
    <Footer />
  </div>
</Layout>