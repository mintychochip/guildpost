---
// Minecraft Category Page - /minecraft/[category]
// Shows servers filtered by game mode category

import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';

// Valid game mode categories (not hosting platforms)
const VALID_CATEGORIES = [
  'Survival', 'SMP', 'PvP', 'Skyblock', 'Factions', 
  'Prison', 'Minigames', 'Creative', 'Hardcore', 
  'Anarchy', 'RPG', 'Modded', 'Pixelmon', 'Multiplayer',
  'Bedwars', 'Towny', 'Economy', 'Roleplay'
];

// Pre-render all valid category pages
export async function getStaticPaths() {
  return VALID_CATEGORIES.map(category => ({
    params: { category: category.toLowerCase() },
    props: { category }
  }));
}

const { category } = Astro.params;
const categoryTitle = category.charAt(0).toUpperCase() + category.slice(1);
---

<Layout 
  title={`${categoryTitle} Minecraft Servers | GuildPost`}
  description={`Browse ${categoryTitle} Minecraft servers on GuildPost. Find the best multiplayer ${category} servers with live player counts.`}
  url={`https://guildpost.tech/minecraft/${category}`}
>
  <div class="min-h-screen bg-[#0a0a0f]">
    <Header />
    
    <main class="max-w-6xl mx-auto px-4 py-8">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm text-[#8892b0] mb-6">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <a href="/minecraft" class="hover:text-white transition-colors">Minecraft</a>
        <span>/</span>
        <span class="text-white capitalize">{category}</span>
      </nav>

      <h1 class="text-4xl font-black text-white mb-4 capitalize">
        {categoryTitle} Servers
      </h1>
      <p class="text-[#8892b0] text-lg mb-8 max-w-2xl">
        Discover the best {categoryTitle} Minecraft servers. Browse by player count, votes, and more.
      </p>

      <!-- Servers List -->
      <div id="servers-list" class="grid gap-4 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
        <div class="col-span-full text-center py-12 text-[#8892b0]">Loading {categoryTitle} servers...</div>
      </div>
    </main>

    <footer class="px-4 py-8 border-t border-[#2a2a3a] mt-12">
      <div class="max-w-6xl mx-auto text-center text-[#8892b0]">
        <p>
          <a href="/minecraft" class="text-[#00f5d4] hover:underline">← Back to all Minecraft servers</a>
        </p>
      </div>
    </footer>
  </div>
</Layout>

<script>
  import { createClient } from '@supabase/supabase-js';
  
  const supabaseUrl = 'https://wpxutsdbiampnxfgkjwq.supabase.co';
  const supabaseKey = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6IndweHV0c2RiaWFtcG54ZmdrandxIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzUzNTEwMDQsImV4cCI6MjA5MDkyNzAwNH0.35hrTSgxQnICpLOY3g6W3eNxxe7DKCc3q165tyb0Ieo';
  
  // Get category from URL
  const category = window.location.pathname.split('/').pop().toLowerCase();
  
  async function loadServers() {
    const supabase = createClient(supabaseUrl, supabaseKey);
    
    // Fetch servers with this category tag
    const { data: servers, error } = await supabase
      .from('servers')
      .select('*')
      .contains('tags', [category.charAt(0).toUpperCase() + category.slice(1)]);
    
    if (error) {
      console.error('Error loading servers:', error);
      document.getElementById('servers-list').innerHTML = 
        '<div class="col-span-full text-center py-12 text-[#ff3864]">Error loading servers</div>';
      return;
    }
    
    if (!servers || servers.length === 0) {
      document.getElementById('servers-list').innerHTML = 
        `<div class="col-span-full text-center py-12 text-[#8892b0]">No ${category} servers found</div>`;
      return;
    }
    
    // Render servers
    const container = document.getElementById('servers-list');
    container.innerHTML = servers.map(server => `
      <a href="/servers/${server.id}" class="block p-6 bg-[#12121a] border border-[#2a2a3a] hover:border-[#00f5d4] transition-all group">
        <div class="flex items-start gap-4">
          <div class="w-16 h-16 bg-[#1a1a25] rounded-lg flex items-center justify-center text-2xl shrink-0">
            ⛏
          </div>
          <div class="flex-1 min-w-0">
            <h3 class="font-bold text-white group-hover:text-[#00f5d4] transition-colors truncate">${server.name}</h3>
            <p class="text-[#8892b0] text-sm truncate">${server.ip}:${server.port}</p>
            <div class="flex flex-wrap gap-1 mt-2">
              ${server.tags?.slice(0, 3).map(tag => 
                `<span class="px-2 py-0.5 bg-[#1a1a25] text-[#8892b0] text-xs rounded">${tag}</span>`
              ).join('') || ''}
            </div>
            <div class="flex items-center gap-4 mt-3 text-sm">
              <span class="text-[#00f5d4]">${server.players_online || 0} online</span>
              <span class="text-[#8892b0]">${server.vote_count || 0} votes</span>
            </div>
          </div>
        </div>
      </a>
    `).join('');
  }
  
  loadServers();
</script>
