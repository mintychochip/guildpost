---
// GuildPost Astro - Main Homepage
// Static site with client-side Supabase data fetching

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import AnimatedStat from '../components/AnimatedStat.astro';

// Inline Arrow SVG component
const ArrowIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>`;

// Game categories data
const gameCategories = [
  {
    id: "minecraft",
    name: "Minecraft",
    description: "PvP, Survival, Skyblock, Factions & more",
    iconColor: "#00f5d4",
    serverCount: 1064,
    href: "/minecraft",
    featured: true,
  },
  {
    id: "rust",
    name: "Rust",
    description: "Coming soon",
    iconColor: "#ff3864",
    serverCount: 0,
    href: "#",
    featured: false,
  },
  {
    id: "cs2",
    name: "CS2",
    description: "Coming soon",
    iconColor: "#9d4edd",
    serverCount: 0,
    href: "#",
    featured: false,
  },
];
---

<Layout 
  title="GuildPost - Find Your Server | Minecraft, Rust, CS2 Server List"
  description="Discover the best game servers on GuildPost. Browse 2,000+ Minecraft servers including PvP, Survival, Skyblock, Factions, SMP & more. Find your next multiplayer home."
  url="https://guildpost.tech"
  keywords="minecraft servers, server list, minecraft multiplayer, game servers, pvp servers, survival servers, skyblock, factions, smp, rust servers, cs2 servers"
>
  <div class="min-h-screen bg-[#0a0a0f]">
    <Header />

    <!-- Hero Section -->
    <section class="px-4 py-20 md:py-32">
      <div class="max-w-6xl mx-auto text-center">
        <h1 class="text-5xl md:text-7xl font-black mb-6">
          <span class="text-white">Find Your</span>
          <br />
          <span class="text-[#ff3864]">SERVER</span>
        </h1>
        <p class="text-[#8892b0] text-xl md:text-2xl max-w-2xl mx-auto mb-12">
          The ultimate directory for game servers. 
          From Minecraft to Rust, discover your next multiplayer home.
        </p>

        <!-- Animated Stats -->
        <div 
          class="flex justify-center gap-8 md:gap-16 mb-8 py-6 px-8 bg-[#12121a] border border-[#2a2a3a] max-w-2xl mx-auto"
          style="clip-path: polygon(5% 0, 100% 0, 95% 100%, 0 100%)"
        >
          <AnimatedStat value={1064} label="Servers" color="#00f5d4" />
          <AnimatedStat value={50} suffix="+" label="Game Modes" color="#00f5d4" />
          <AnimatedStat value={0} label="Fake Reviews" color="#ff3864" />
        </div>

        <!-- Inline Wizard Search -->
        <div class="max-w-3xl mx-auto mt-8 mb-4">
          <div class="relative">
            <input 
              type="text" 
              id="wizard-search"
              placeholder="Describe what you're looking for (e.g., 'minecraft pvp server with factions')..."
              class="w-full px-6 py-4 bg-[#12121a] border border-[#2a2a3a] rounded-lg text-white text-lg placeholder-[#8892b0] focus:outline-none focus:border-[#00f5d4] pr-32"
            />
            <button 
              id="wizard-search-btn"
              class="absolute right-2 top-1/2 transform -translate-y-1/2 px-6 py-2.5 bg-[#00f5d4] text-[#0a0a0f] font-bold rounded hover:bg-[#00d4b8] transition-colors flex items-center gap-2"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
              Find
            </button>
          </div>
          <p class="text-[#8892b0] text-sm mt-2 text-left">
            Or try: <span class="text-[#00f5d4] cursor-pointer hover:underline" onclick="setWizardSearch('survival building smp')">survival building smp</span>, 
            <span class="text-[#00f5d4] cursor-pointer hover:underline" onclick="setWizardSearch('hardcore pvp')">hardcore pvp</span>, 
            <span class="text-[#00f5d4] cursor-pointer hover:underline" onclick="setWizardSearch('creative plot world')">creative plot world</span>
          </p>
        </div>

        <!-- Wizard Inline Container -->
        <div id="inline-wizard" class="hidden max-w-3xl mx-auto mt-6">
          <div class="bg-[#12121a] border border-[#2a2a3a] rounded-lg p-6">
            <div id="wizard-question" class="mb-6">
              <h3 class="text-xl font-bold text-white mb-2" id="wizard-q-text"></h3>
              <p class="text-[#8892b0] text-sm">Select an option to refine your search</p>
            </div>
            <div id="wizard-options" class="grid gap-3 grid-cols-1 sm:grid-cols-2">
              <!-- Options populated by JS -->
            </div>
            <div class="mt-4 flex justify-between">
              <button id="wizard-back" class="text-[#8892b0] hover:text-white text-sm flex items-center gap-1 hidden">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
                Back
              </button>
              <button id="wizard-skip" class="text-[#8892b0] hover:text-white text-sm">
                Skip to results
              </button>
            </div>
          </div>
        </div>

        <!-- Wizard Results -->
        <div id="wizard-results" class="hidden max-w-6xl mx-auto mt-8">
          <h3 class="text-2xl font-bold text-white mb-4">Recommended Servers</h3>
          <div id="wizard-results-grid" class="grid gap-4 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
            <!-- Results populated by JS -->
          </div>
        </div>

        <!-- CTA Buttons -->
        <div class="flex flex-wrap justify-center gap-4 mt-8">
          <a
            href="/minecraft"
            class="inline-flex items-center gap-2 bg-[#00f5d4] text-[#0a0a0f] px-8 py-4 font-bold text-lg hover:bg-[#00d4b8] transition-colors"
            style="clip-path: polygon(10% 0, 100% 0, 100% 70%, 90% 100%, 0 100%, 0 30%)"
          >
            Browse All
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a
            href="/wizard"
            class="inline-flex items-center gap-2 border-2 border-[#00f5d4] text-[#00f5d4] px-8 py-4 font-bold text-lg hover:bg-[#00f5d4] hover:text-[#0a0a0f] transition-colors"
            style="clip-path: polygon(0 0, 90% 0, 100% 30%, 100% 100%, 10% 100%, 0 70%)"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
            Full Wizard
          </a>
          <a
            href="/submit"
            class="inline-flex items-center gap-2 border-2 border-[#2a2a3a] text-white px-8 py-4 font-bold text-lg hover:border-[#00f5d4] hover:text-[#00f5d4] transition-colors"
            style="clip-path: polygon(0 0, 90% 0, 100% 30%, 100% 100%, 10% 100%, 0 70%)"
          >
            Add Server
          </a>
        </div>
        
        <!-- Surprise Me Button -->
        <div class="mt-6">
          <button
            id="surprise-btn"
            class="inline-flex items-center gap-2 text-[#8892b0] hover:text-[#ff3864] transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
              <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
              <line x1="12" y1="22.08" x2="12" y2="12"/>
            </svg>
            🎲 Surprise Me - Random Server
          </button>
        </div>
      </div>
    </section>

    <!-- Game Categories -->
    <section class="px-4 py-16 border-t border-[#1a1a25]">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-3xl font-bold text-white mb-8 text-center">
          Browse by Game
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {gameCategories.map((game) => (
            <a
              href={game.href}
              class={`group p-8 border-2 transition-all ${
                game.featured
                  ? "border-[#00f5d4] bg-[#00f5d4]/5 hover:bg-[#00f5d4]/10"
                  : "border-[#2a2a3a] opacity-60 hover:opacity-100 hover:border-[#3a3a4a]"
              }`}
              style="clip-path: polygon(5% 0, 100% 0, 100% 95%, 95% 100%, 0 100%, 0 5%)"
            >
              <div class="mb-4" style={`color: ${game.iconColor}`}>
                {game.id === 'minecraft' && (
                  <!-- Minecraft Grass Block SVG -->
                  <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <!-- Top face -->
                    <path d="M24 0L48 12L24 24L0 12L24 0Z" fill="#5D8C3A"/>
                    <!-- Front face -->
                    <path d="M24 24L48 12V36L24 48V24Z" fill="#735037"/>
                    <!-- Left face -->
                    <path d="M24 24L0 12V36L24 48V24Z" fill="#8B654D"/>
                    <!-- Dirt top edges -->
                    <path d="M0 12L24 24L48 12L24 0L0 12Z" fill="#5D8C3A"/>
                    <!-- Grass highlight -->
                    <path d="M24 2L44 12L24 22L4 12L24 2Z" fill="#6B9E47"/>
                  </svg>
                )}
                {game.id === 'rust' && (
                  <!-- Rust Gear SVG -->
                  <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="24" cy="24" r="12" stroke={game.iconColor} stroke-width="3" fill="none"/>
                    <circle cx="24" cy="24" r="6" stroke={game.iconColor} stroke-width="2" fill="none"/>
                    <!-- Gear teeth -->
                    <path d="M24 4V10" stroke={game.iconColor} stroke-width="3" stroke-linecap="round"/>
                    <path d="M24 38V44" stroke={game.iconColor} stroke-width="3" stroke-linecap="round"/>
                    <path d="M4 24H10" stroke={game.iconColor} stroke-width="3" stroke-linecap="round"/>
                    <path d="M38 24H44" stroke={game.iconColor} stroke-width="3" stroke-linecap="round"/>
                    <path d="M10 10L14 14" stroke={game.iconColor} stroke-width="3" stroke-linecap="round"/>
                    <path d="M34 34L38 38" stroke={game.iconColor} stroke-width="3" stroke-linecap="round"/>
                    <path d="M38 10L34 14" stroke={game.iconColor} stroke-width="3" stroke-linecap="round"/>
                    <path d="M14 34L10 38" stroke={game.iconColor} stroke-width="3" stroke-linecap="round"/>
                  </svg>
                )}
                {game.id === 'cs2' && (
                  <!-- CS2 Counter-Strike Icon -->
                  <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="24" cy="24" r="22" stroke={game.iconColor} stroke-width="3" fill="none"/>
                    <path d="M24 10V24L34 30" stroke={game.iconColor} stroke-width="3" stroke-linecap="round"/>
                    <circle cx="24" cy="24" r="4" fill={game.iconColor}/>
                    <!-- Crosshair elements -->
                    <path d="M24 4V8" stroke={game.iconColor} stroke-width="2" stroke-linecap="round"/>
                    <path d="M24 40V44" stroke={game.iconColor} stroke-width="2" stroke-linecap="round"/>
                    <path d="M4 24H8" stroke={game.iconColor} stroke-width="2" stroke-linecap="round"/>
                    <path d="M40 24H44" stroke={game.iconColor} stroke-width="2" stroke-linecap="round"/>
                  </svg>
                )}
              </div>
              <h3 class="text-2xl font-bold text-white mb-2">
                {game.name}
              </h3>
              <p class="text-[#8892b0] mb-4">
                {game.description}
              </p>
              {game.serverCount > 0 && (
                <p class="text-[#00f5d4] font-bold">
                  {game.serverCount.toLocaleString()} servers
                </p>
              )}
              {game.featured && (
                <div class="mt-4 flex items-center gap-2 text-[#00f5d4]">
                  <span class="text-sm font-medium">Explore</span>
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </div>
              )}
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Featured Minecraft Servers - Client Side Fetched -->
    <section class="px-4 py-16 border-t border-[#1a1a25]">
      <div class="max-w-6xl mx-auto">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-3xl font-bold text-white">
            Featured Minecraft Servers
          </h2>
          <a 
            href="/minecraft" 
            class="text-[#00f5d4] hover:underline flex items-center gap-2"
          >
            View All
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>

        <!-- Server grid - populated client-side -->
        <div id="featured-servers" class="grid gap-4 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
          <!-- Loading state -->
          <div class="col-span-full text-center py-12 text-[#8892b0]">
            Loading servers...
          </div>
        </div>
      </div>
    </section>

    <!-- Why GuildPost -->
    <section class="px-4 py-16 border-t border-[#1a1a25]">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-3xl font-bold text-white mb-12 text-center">
          Why GuildPost?
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="text-center">
            <div class="w-16 h-16 bg-[#12121a] border border-[#2a2a3a] flex items-center justify-center mx-auto mb-4 text-2xl">
              🎮
            </div>
            <h3 class="text-xl font-bold text-white mb-2">
              Multi-Game Support
            </h3>
            <p class="text-[#8892b0]">
              Starting with Minecraft, expanding to Rust, CS2, and more.
            </p>
          </div>

          <div class="text-center">
            <div class="w-16 h-16 bg-[#12121a] border border-[#2a2a3a] flex items-center justify-center mx-auto mb-4 text-2xl">
              👥
            </div>
            <h3 class="text-xl font-bold text-white mb-2">
              Community Driven
            </h3>
            <p class="text-[#8892b0]">
              Real player votes and reviews. No pay-to-win placement.
            </p>
          </div>

          <div class="text-center">
            <div class="w-16 h-16 bg-[#12121a] border border-[#2a2a3a] flex items-center justify-center mx-auto mb-4 text-2xl">
              📊
            </div>
            <h3 class="text-xl font-bold text-white mb-2">
              Live Status
            </h3>
            <p class="text-[#8892b0]">
              Real-time player counts and latency. Know before you join.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Footer CTA -->
    <section class="px-4 py-16 border-t border-[#1a1a25]">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl font-bold text-white mb-4">
          Ready to Find Your Server?
        </h2>
        <p class="text-[#8892b0] mb-8">
          Join thousands of players discovering their next favorite server.
        </p>
        <a
          href="/minecraft"
          class="inline-flex items-center gap-2 bg-[#ff3864] text-white px-8 py-4 font-bold text-lg hover:bg-[#e63357] transition-colors"
          style="clip-path: polygon(10% 0, 100% 0, 100% 70%, 90% 100%, 0 100%, 0 30%)"
        >
          Start Browsing
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </section>

    <!-- Footer -->
    <footer class="px-4 py-8 border-t border-[#2a2a3a]">
      <div class="max-w-6xl mx-auto text-center text-[#8892b0]">
        <p>
          Built for the community. Not for profit. 
          <a href="https://github.com/mintychochip/guildpost" class="text-[#00f5d4] hover:underline ml-2">
            Open source
          </a>
        </p>
      </div>
    </footer>
  </div>
</Layout>

<!-- Client-side script to fetch servers -->
<script>
  import { createClient } from '@supabase/supabase-js';
  
  const supabaseUrl = 'https://wpxutsdbiampnxfgkjwq.supabase.co';
  const supabaseKey = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6IndweHV0c2RiaWFtcG54ZmdrandxIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzUzNTEwMDQsImV4cCI6MjA5MDkyNzAwNH0.35hrTSgxQnICpLOY3g6W3eNxxe7DKCc3q165tyb0Ieo';
  
  async function loadServers() {
    const supabase = createClient(supabaseUrl, supabaseKey);
    
    const { data: servers, error } = await supabase
      .from('servers')
      .select('id, ip, port, name, description, version, tags, verified, vote_count, icon, banner')
      .order('vote_count', { ascending: false })
      .limit(6);
    
    if (error) {
      console.error('Error loading servers:', error);
      document.getElementById('featured-servers').innerHTML = `
        <div class="col-span-full text-center py-12 text-[#8892b0]">
          Error loading servers. Please try again.
        </div>
      `;
      return;
    }
    
    if (!servers || servers.length === 0) {
      document.getElementById('featured-servers').innerHTML = `
        <div class="col-span-full text-center py-12 text-[#8892b0]">
          No servers found.
        </div>
      `;
      return;
    }
    
    // Render servers
    const container = document.getElementById('featured-servers');
    container.innerHTML = servers.map(server => `
      <a href="/servers/${server.id}" class="block p-5 bg-[#12121a] border border-[#2a2a3a] hover:border-[#00f5d4] transition-colors group rounded-lg">
        <div class="flex items-start gap-4 mb-4">
          ${server.icon ? `
            <img src="${server.icon}" alt="" class="w-14 h-14 rounded bg-[#1a1a25]" loading="lazy" />
          ` : `
            <div class="w-14 h-14 rounded bg-[#1a1a25] flex items-center justify-center">
              <span class="text-[#00f5d4] text-2xl">⛏</span>
            </div>
          `}
          <div class="flex-1 min-w-0">
            <h3 class="font-bold text-white group-hover:text-[#00f5d4] transition-colors truncate text-lg">
              ${server.name}
            </h3>
            <p class="text-sm text-[#8892b0] font-mono truncate">${server.ip}:${server.port}</p>
          </div>
        </div>
        
        <!-- Stats Row -->
        <div class="flex items-center gap-4 mb-3 text-sm">
          <span class="flex items-center gap-1 ${server.players_online > 0 ? 'text-green-500' : 'text-[#8892b0]'}">
            <span class="w-1.5 h-1.5 rounded-full ${server.players_online > 0 ? 'bg-green-500' : 'bg-gray-500'}"></span>
            ${server.players_online || 0}/${server.max_players || '?'} online
          </span>
          <span class="flex items-center gap-1 text-[#ff3864]">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"/></svg>
            ${server.vote_count || 0} votes
          </span>
        </div>
        
        <!-- Tags -->
        <div class="flex flex-wrap gap-1">
          ${(server.tags || []).slice(0, 3).map(tag => `
            <span class="text-xs px-2 py-1 bg-[#1a1a25] text-[#8892b0] rounded">${tag}</span>
          `).join('')}
          ${server.version ? `<span class="text-xs px-2 py-1 bg-[#00f5d4]/10 text-[#00f5d4] rounded">${server.version}</span>` : ''}
        </div>
      </a>
    `).join('');
  }
  
  // Load servers when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', loadServers);
  } else {
    loadServers();
  }
  
  // Surprise Me - Random Server
  const surpriseBtn = document.getElementById('surprise-btn');
  surpriseBtn?.addEventListener('click', async () => {
    surpriseBtn.innerHTML = `
      <svg class="animate-spin" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
        <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
        <line x1="12" y1="22.08" x2="12" y2="12"/>
      </svg>
      Finding random server...
    `;
    
    const supabase = createClient(supabaseUrl, supabaseKey);
    
    // Get count first
    const { count } = await supabase
      .from('servers')
      .select('*', { count: 'exact', head: true });
    
    if (!count) {
      showToast('No servers available', 'error');
      return;
    }
    
    // Get random offset
    const randomOffset = Math.floor(Math.random() * count);
    
    // Fetch random server
    const { data: servers } = await supabase
      .from('servers')
      .select('id, name')
      .range(randomOffset, randomOffset)
      .limit(1);
    
    if (servers && servers.length > 0) {
      window.location.href = `/servers/${servers[0].id}`;
    } else {
      surpriseBtn.innerHTML = `
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
          <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
          <line x1="12" y1="22.08" x2="12" y2="12"/>
        </svg>
        🎲 Surprise Me - Random Server
      `;
      showToast('Try again!', 'error');
    }
  });
  
  // Inline Wizard
  const wizardSearch = document.getElementById('wizard-search');
  const wizardSearchBtn = document.getElementById('wizard-search-btn');
  const inlineWizard = document.getElementById('inline-wizard');
  const wizardResults = document.getElementById('wizard-results');
  
  let wizardStep = 0;
  let wizardAnswers = [];
  let searchQuery = '';
  
  const wizardQuestions = [
    {
      question: "What type of gameplay experience?",
      options: [
        { id: 'pvp', label: "PvP & Combat", icon: "⚔️", tags: ['PvP', 'Factions'] },
        { id: 'survival', label: "Survival & Building", icon: "🏠", tags: ['Survival', 'SMP'] },
        { id: 'creative', label: "Creative Mode", icon: "🎨", tags: ['Creative'] },
        { id: 'minigames', label: "Minigames", icon: "🎮", tags: ['Minigames'] },
      ]
    },
    {
      question: "What difficulty level?",
      options: [
        { id: 'hardcore', label: "Hardcore", icon: "💀", tags: ['Hardcore'] },
        { id: 'hard', label: "Hard", icon: "⚡", tags: ['Hard'] },
        { id: 'normal', label: "Normal", icon: "⛏️", tags: [] },
        { id: 'peaceful', label: "Peaceful/Easy", icon: "🌸", tags: ['Peaceful'] },
      ]
    },
    {
      question: "Preferred community size?",
      options: [
        { id: 'small', label: "Small (10-50)", icon: "👥", tags: ['Small'] },
        { id: 'medium', label: "Medium (50-200)", icon: "👨‍👩‍👧‍👦", tags: ['Medium'] },
        { id: 'large', label: "Large (200+)", icon: "🌆", tags: ['Large'] },
        { id: 'any', label: "Any size", icon: "🤷", tags: [] },
      ]
    }
  ];
  
  window.setWizardSearch = (text) => {
    wizardSearch.value = text;
    startWizard();
  };
  
  function startWizard() {
    searchQuery = wizardSearch.value.trim();
    if (!searchQuery) return;
    
    wizardStep = 0;
    wizardAnswers = [];
    inlineWizard.classList.remove('hidden');
    wizardResults.classList.add('hidden');
    renderWizardStep();
  }
  
  function renderWizardStep() {
    const q = wizardQuestions[wizardStep];
    document.getElementById('wizard-q-text').textContent = q.question;
    
    const optionsContainer = document.getElementById('wizard-options');
    optionsContainer.innerHTML = q.options.map(opt => `
      <button 
        class="wizard-option-btn p-4 bg-[#0a0a0f] border border-[#2a2a3a] hover:border-[#00f5d4] rounded-lg transition-all text-left flex items-center gap-3"
        onclick="selectWizardOption('${opt.id}')"
      >
        <span class="text-2xl">${opt.icon}</span>
        <span class="font-bold text-white">${opt.label}</span>
      </button>
    `).join('');
    
    document.getElementById('wizard-back').classList.toggle('hidden', wizardStep === 0);
  }
  
  window.selectWizardOption = (optionId) => {
    const q = wizardQuestions[wizardStep];
    const selected = q.options.find(o => o.id === optionId);
    wizardAnswers.push(selected);
    
    if (wizardStep < wizardQuestions.length - 1) {
      wizardStep++;
      renderWizardStep();
    } else {
      finishWizard();
    }
  };
  
  document.getElementById('wizard-back')?.addEventListener('click', () => {
    if (wizardStep > 0) {
      wizardStep--;
      wizardAnswers.pop();
      renderWizardStep();
    }
  });
  
  document.getElementById('wizard-skip')?.addEventListener('click', finishWizard);
  
  async function finishWizard() {
    inlineWizard.classList.add('hidden');
    wizardResults.classList.remove('hidden');
    
    const resultsGrid = document.getElementById('wizard-results-grid');
    resultsGrid.innerHTML = `
      <div class="col-span-full text-center py-12">
        <div class="w-8 h-8 border-2 border-[#2a2a3a] border-t-[#00f5d4] rounded-full animate-spin mx-auto mb-4"></div>
        <p class="text-[#8892b0]">Finding perfect matches...</p>
      </div>
    `;
    
    // Collect all tags from answers
    const allTags = wizardAnswers.flatMap(a => a.tags || []);
    
    const supabase = createClient(supabaseUrl, supabaseKey);
    
    let query = supabase.from('servers').select('*');
    
    // If we have tags, filter by them
    if (allTags.length > 0) {
      query = query.contains('tags', allTags.slice(0, 2));
    }
    
    // Also try to match search query in name/description
    if (searchQuery) {
      query = query.or(`name.ilike.%${searchQuery}%,description.ilike.%${searchQuery}%`);
    }
    
    const { data: servers } = await query
      .order('vote_count', { ascending: false })
      .limit(6);
    
    if (!servers || servers.length === 0) {
      resultsGrid.innerHTML = `
        <div class="col-span-full text-center py-12">
          <p class="text-[#8892b0] mb-4">No exact matches found.</p>
          <a href="/minecraft" class="px-6 py-3 bg-[#00f5d4] text-[#0a0a0f] font-bold rounded-lg inline-block">
            Browse All Servers
          </a>
        </div>
      `;
      return;
    }
    
    resultsGrid.innerHTML = servers.map(server => `
      <a href="/servers/${server.id}" class="block p-4 bg-[#12121a] border border-[#2a2a3a] hover:border-[#00f5d4] rounded-lg transition-all group">
        <div class="flex items-start gap-3">
          <div class="w-12 h-12 bg-[#1a1a25] rounded-lg flex items-center justify-center">
            ${server.icon ? 
              `<img src="${server.icon}" alt="" class="w-full h-full object-cover rounded-lg">` : 
              `<span class="text-[#00f5d4] text-xl">⛏</span>`
            }
          </div>
          <div class="flex-1 min-w-0">
            <h3 class="font-bold text-white group-hover:text-[#00f5d4] transition-colors truncate">${server.name}</h3>
            <p class="text-[#8892b0] text-sm truncate">${server.ip}:${server.port}</p>
            <div class="flex items-center gap-3 mt-2 text-xs">
              <span class="${server.status === 'online' ? 'text-green-500' : 'text-gray-500'}">
                ${server.status === 'online' ? '● Online' : '○ Offline'}
              </span>
              <span class="text-[#8892b0]">${server.players_online || 0} players</span>
              <span class="text-[#ff3864]">▲ ${server.vote_count || 0}</span>
            </div>
          </div>
        </div>
      </a>
    `).join('');
  }
  
  wizardSearchBtn?.addEventListener('click', startWizard);
  wizardSearch?.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') startWizard();
  });
</script>