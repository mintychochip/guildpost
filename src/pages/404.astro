---
// 404 Page - Not Found
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const suggestedPaths = [
  { label: 'Browse Minecraft Servers', href: '/minecraft', icon: '⛏' },
  { label: 'Submit Your Server', href: '/submit', icon: '+' },
  { label: 'View Favorites', href: '/favorites', icon: '♡' },
];
---

<Layout 
  title="Page Not Found | GuildPost"
  description="The page you're looking for doesn't exist. Browse Minecraft servers or submit your own."
>
  <div class="min-h-screen" style="background-color: var(--bg-primary);">
    <Header />
    
    <main class="max-w-4xl mx-auto px-4 py-20">
      <div class="text-center">
        <!-- 404 Graphic -->
        <div class="relative inline-block mb-8">
          <div class="w-32 h-32 bg-[#1a1a25] rounded-2xl flex items-center justify-center mx-auto mb-4 border border-[#2a2a3a]">
            <span class="text-6xl">⛏</span>
          </div>
          <div class="absolute -top-2 -right-2 w-10 h-10 bg-[#ff3864] rounded-full flex items-center justify-center text-white font-bold text-lg shadow-lg">
            ?
          </div>
        </div>
        
        <h1 class="text-6xl font-black text-white mb-4">404</h1>
        <p class="text-2xl text-[#8892b0] mb-2">Page Not Found</p>
        <p class="text-[#8892b0] mb-8 max-w-md mx-auto">
          Looks like this page mined too deep and hit bedrock. Let's get you back to the surface.
        </p>
        
        <!-- Action Buttons -->
        <div class="flex flex-wrap justify-center gap-4 mb-12">
          <a 
            href="/minecraft" 
            class="px-6 py-3 bg-[#00f5d4] hover:bg-[#00d4b8] text-[#0a0a0f] font-bold rounded-lg transition-colors flex items-center gap-2"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
              <polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
            Go Home
          </a>
          <button 
            onclick="history.back()"
            class="px-6 py-3 bg-[#1a1a25] hover:bg-[#2a2a3a] text-white font-bold rounded-lg transition-colors flex items-center gap-2"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="m12 19-7-7 7-7"/>
              <path d="M19 12H5"/>
            </svg>
            Go Back
          </button>
        </div>
        
        <!-- Suggested Links -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 max-w-2xl mx-auto">
          {suggestedPaths.map(path => (
            <a 
              href={path.href}
              class="p-4 bg-[#12121a] border border-[#2a2a3a] hover:border-[#00f5d4] rounded-lg transition-colors group"
            >
              <div class="w-10 h-10 bg-[#1a1a25] rounded-lg flex items-center justify-center mx-auto mb-2 group-hover:bg-[#00f5d4]/20">
                <span class="text-xl text-[#00f5d4]">{path.icon}</span>
              </div>
              <span class="text-[#8892b0] group-hover:text-white text-sm font-medium">
                {path.label}
              </span>
            </a>
          ))}
        </div>
      </div>
    </main>
    
    <Footer />
  </div>
</Layout>