---
// Premium Listings - Monetization page for server owners
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const tiers = [
  {
    id: 'free',
    name: 'Basic',
    price: 0,
    priceLabel: 'Free',
    description: 'Standard server listing',
    features: [
      'Basic server listing',
      'Server detail page',
      'Vote tracking',
      'Standard analytics',
      'Community support',
    ],
    notIncluded: [
      'Featured placement',
      'Custom banner',
      'Priority support',
      'Advanced analytics',
    ],
    cta: 'Get Started',
    ctaLink: '/submit',
    highlight: false,
  },
  {
    id: 'premium',
    name: 'Premium',
    price: 9.99,
    priceLabel: '$9.99/mo',
    description: 'Enhanced visibility & features',
    features: [
      'Everything in Basic',
      'Featured badge',
      'Priority placement in listings',
      'Custom banner support',
      'Discord notifications',
      'Priority email support',
      'Remove ads (when implemented)',
    ],
    notIncluded: [
      'Homepage spotlight',
      'Advanced analytics',
    ],
    cta: 'Upgrade to Premium',
    ctaLink: '#upgrade-premium',
    highlight: true,
    badge: 'Most Popular',
  },
  {
    id: 'elite',
    name: 'Elite',
    price: 29.99,
    priceLabel: '$29.99/mo',
    description: 'Maximum exposure & tools',
    features: [
      'Everything in Premium',
      'Homepage spotlight rotation',
      'Advanced analytics dashboard',
      'Player retention insights',
      'Vote conversion tracking',
      'API access for custom integrations',
      'Dedicated support channel',
      'Early access to new features',
    ],
    notIncluded: [],
    cta: 'Go Elite',
    ctaLink: '#upgrade-elite',
    highlight: false,
    badge: 'Best Value',
  },
];

const faqs = [
  {
    q: 'How do I upgrade my server?',
    a: 'Click the Upgrade button on any tier, enter your server ID and email, then complete payment via Stripe. Your server will be upgraded instantly.',
  },
  {
    q: 'Can I downgrade or cancel anytime?',
    a: 'Yes, you can cancel anytime from your dashboard or via the customer portal. Your premium features remain active until the end of your billing period.',
  },
  {
    q: 'What payment methods are accepted?',
    a: 'We accept all major credit cards (Visa, MasterCard, American Express). Stripe handles all payments securely.',
  },
  {
    q: 'How does priority placement work?',
    a: 'Premium servers appear above free servers in category listings and search results. Elite servers get top placement in the homepage spotlight.',
  },
  {
    q: 'Is there a free trial?',
    a: "We don't offer free trials, but you can upgrade for a month and cancel anytime if you're not satisfied.",
  },
];

// Server ID from URL params for pre-filling
const initialServerId = Astro.url.searchParams.get('server') || '';

const testimonials = [
  {
    quote: "Upgrading to Premium doubled our daily vote count within the first week.",
    author: "SkyBlock Legends",
    tier: "Premium",
  },
  {
    quote: "The advanced analytics helped us understand when players are most active.",
    author: "Pixelmon Adventures",
    tier: "Elite",
  },
  {
    quote: "Priority support is amazing - issues get resolved in hours, not days.",
    author: "PvP Network",
    tier: "Elite",
  },
];
---

<Layout 
  title="Premium Listings - Boost Your Server | GuildPost"
  description="Upgrade your Minecraft server listing on GuildPost. Get featured placement, advanced analytics, and priority support with Premium or Elite tiers."
  url="https://guildpost.tech/premium"
  keywords="minecraft server premium, server promotion, featured server listing, minecraft advertising"
>
  <div class="min-h-screen bg-[#0a0a0f]">
    <Header />
    
    <main class="pt-20 pb-16">
      <!-- Hero Section -->
      <div class="max-w-6xl mx-auto px-4 py-16 text-center">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-[#00f5d4]/10 border border-[#00f5d4]/30 rounded-full text-[#00f5d4] text-sm mb-6">
          <span>⭐</span>
          <span>Trusted by 500+ server owners</span>
        </div>
        
        <h1 class="text-4xl md:text-6xl font-black text-white mb-6">
          Get Your Server <span class="text-[#ff3864]">Noticed</span>
        </h1>
        <p class="text-[#8892b0] text-lg md:text-xl max-w-2xl mx-auto mb-8">
          Join thousands of server owners who use GuildPost Premium to attract more players, 
          track advanced metrics, and grow their community.
        </p>
        
        <div class="flex flex-wrap items-center justify-center gap-4">
          <a href="#pricing" class="px-8 py-4 bg-[#00f5d4] hover:bg-[#00d4b8] text-[#0a0a0f] font-bold rounded-lg transition-colors">
            View Pricing
          </a>
          <a href="/dashboard" class="px-8 py-4 bg-[#1a1a25] hover:bg-[#2a2a3a] text-white border border-[#2a2a3a] rounded-lg transition-colors">
            Check Your Server
          </a>
        </div>
      </div>

      <!-- Stats Bar -->
      <div class="border-y border-[#2a2a3a] bg-[#12121a]/50">
        <div class="max-w-6xl mx-auto px-4 py-8">
          <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
            <div>
              <div class="text-3xl md:text-4xl font-black text-[#00f5d4]">2M+</div>
              <div class="text-[#8892b0] text-sm mt-1">Monthly page views</div>
            </div>
            <div>
              <div class="text-3xl md:text-4xl font-black text-[#ff3864]">50K+</div>
              <div class="text-[#8892b0] text-sm mt-1">Active players</div>
            </div>
            <div>
              <div class="text-3xl md:text-4xl font-black text-[#00f5d4]">3.3K+</div>
              <div class="text-[#8892b0] text-sm mt-1">Listed servers</div>
            </div>
            <div>
              <div class="text-3xl md:text-4xl font-black text-white">500+</div>
              <div class="text-[#8892b0] text-sm mt-1">Premium members</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Pricing Section -->
      <div id="pricing" class="max-w-6xl mx-auto px-4 py-20">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Choose Your Plan</h2>
          <p class="text-[#8892b0] max-w-xl mx-auto">
            Upgrade your server listing to reach more players and unlock powerful tools
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {tiers.map((tier) => (
            <div class={`relative p-6 rounded-2xl border ${tier.highlight ? 'border-[#00f5d4] bg-[#00f5d4]/5' : 'border-[#2a2a3a] bg-[#12121a]'} ${tier.highlight ? 'md:scale-105' : ''}`}>
              {tier.badge && (
                <div class={`absolute -top-3 left-1/2 transform -translate-x-1/2 px-3 py-1 ${tier.id === 'premium' ? 'bg-[#00f5d4] text-[#0a0a0f]' : 'bg-[#a855f7] text-white'} text-xs font-bold rounded-full`}>
                  {tier.badge}
                </div>
              )}
              
              <div class="text-center mb-6">
                <h3 class="text-xl font-bold text-white mb-2">{tier.name}</h3>
                <div class="flex items-baseline justify-center gap-1">
                  <span class="text-4xl font-black text-white">${tier.price}</span>
                  {tier.price > 0 && <span class="text-[#8892b0]">/mo</span>}
                </div>
                <p class="text-[#8892b0] text-sm mt-2">{tier.description}</p>
              </div>

              <div class="space-y-3 mb-6">
                {tier.features.map((feature) => (
                  <div class="flex items-start gap-3">
                    <svg class="w-5 h-5 text-[#00f5d4] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                    </svg>
                    <span class="text-white text-sm">{feature}</span>
                  </div>
                ))}
                {tier.notIncluded.map((feature) => (
                  <div class="flex items-start gap-3 opacity-50">
                    <svg class="w-5 h-5 text-[#8892b0] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                    <span class="text-[#8892b0] text-sm line-through">{feature}</span>
                  </div>
                ))}
              </div>

              {tier.id === 'free' ? (
                <a 
                  href={tier.ctaLink}
                  class={`block w-full py-3 px-4 text-center font-bold rounded-lg transition-colors ${
                    tier.highlight 
                      ? 'bg-[#00f5d4] hover:bg-[#00d4b8] text-[#0a0a0f]' 
                      : 'bg-[#1a1a25] hover:bg-[#2a2a3a] text-white border border-[#2a2a3a]'
                  }`}
                >
                  {tier.cta}
                </a>
              ) : (
                <button 
                  class={`checkout-btn block w-full py-3 px-4 text-center font-bold rounded-lg transition-colors ${
                    tier.highlight 
                      ? 'bg-[#00f5d4] hover:bg-[#00d4b8] text-[#0a0a0f]' 
                      : 'bg-[#a855f7] hover:bg-[#9333ea] text-white'
                  }`}
                  data-tier={tier.id}
                  data-price={tier.price}
                >
                  {tier.cta}
                </button>
              )}
            </div>
          ))}
        </div>

        <p class="text-center text-[#8892b0] text-sm mt-8">
          All plans include SSL security, automatic backups, and 99.9% uptime guarantee.
          <br />
          Questions? Contact us at <a href="mailto:premium@guildpost.tech" class="text-[#00f5d4] hover:underline">premium@guildpost.tech</a>
        </p>
      </div>

      <!-- Feature Comparison -->
      <div class="max-w-6xl mx-auto px-4 py-16 border-t border-[#2a2a3a]">
        <h2 class="text-3xl font-bold text-white text-center mb-12">Feature Comparison</h2>
        
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead>
              <tr class="border-b border-[#2a2a3a]">
                <th class="text-left py-4 px-4 text-[#8892b0] font-medium">Feature</th>
                <th class="text-center py-4 px-4 text-white font-bold">Basic</th>
                <th class="text-center py-4 px-4 text-[#00f5d4] font-bold">Premium</th>
                <th class="text-center py-4 px-4 text-[#a855f7] font-bold">Elite</th>
              </tr>
            </thead>
            <tbody class="text-sm">
              <tr class="border-b border-[#2a2a3a]/50">
                <td class="py-4 px-4 text-white">Server Listing</td>
                <td class="text-center py-4 px-4 text-[#00f5d4]">✓</td>
                <td class="text-center py-4 px-4 text-[#00f5d4]">✓</td>
                <td class="text-center py-4 px-4 text-[#00f5d4]">✓</td>
              </tr>
              <tr class="border-b border-[#2a2a3a]/50">
                <td class="py-4 px-4 text-white">Server Detail Page</td>
                <td class="text-center py-4 px-4 text-[#00f5d4]">✓</td>
                <td class="text-center py-4 px-4 text-[#00f5d4]">✓</td>
                <td class="text-center py-4 px-4 text-[#00f5d4]">✓</td>
              </tr>
              <tr class="border-b border-[#2a2a3a]/50">
                <td class="py-4 px-4 text-white">Vote Tracking</td>
                <td class="text-center py-4 px-4 text-[#00f5d4]">✓</td>
                <td class="text-center py-4 px-4 text-[#00f5d4]">✓</td>
                <td class="text-center py-4 px-4 text-[#00f5d4]">✓</td>
              </tr>
              <tr class="border-b border-[#2a2a3a]/50">
                <td class="py-4 px-4 text-white">Featured Badge</td>
                <td class="text-center py-4 px-4 text-[#8892b0]">—</td>
                <td class="text-center py-4 px-4 text-[#00f5d4]">✓</td>
                <td class="text-center py-4 px-4 text-[#00f5d4]">✓</td>
              </tr>
              <tr class="border-b border-[#2a2a3a]/50">
                <td class="py-4 px-4 text-white">Priority Placement</td>
                <td class="text-center py-4 px-4 text-[#8892b0]">—</td>
                <td class="text-center py-4 px-4 text-[#00f5d4]">✓</td>
                <td class="text-center py-4 px-4 text-[#00f5d4]">✓</td>
              </tr>
              <tr class="border-b border-[#2a2a3a]/50">
                <td class="py-4 px-4 text-white">Custom Banner</td>
                <td class="text-center py-4 px-4 text-[#8892b0]">—</td>
                <td class="text-center py-4 px-4 text-[#00f5d4]">✓</td>
                <td class="text-center py-4 px-4 text-[#00f5d4]">✓</td>
              </tr>
              <tr class="border-b border-[#2a2a3a]/50">
                <td class="py-4 px-4 text-white">Homepage Spotlight</td>
                <td class="text-center py-4 px-4 text-[#8892b0]">—</td>
                <td class="text-center py-4 px-4 text-[#8892b0]">—</td>
                <td class="text-center py-4 px-4 text-[#00f5d4]">✓</td>
              </tr>
              <tr class="border-b border-[#2a2a3a]/50">
                <td class="py-4 px-4 text-white">Advanced Analytics</td>
                <td class="text-center py-4 px-4 text-[#8892b0]">—</td>
                <td class="text-center py-4 px-4 text-[#8892b0]">—</td>
                <td class="text-center py-4 px-4 text-[#00f5d4]">✓</td>
              </tr>
              <tr class="border-b border-[#2a2a3a]/50">
                <td class="py-4 px-4 text-white">API Access</td>
                <td class="text-center py-4 px-4 text-[#8892b0]">—</td>
                <td class="text-center py-4 px-4 text-[#8892b0]">—</td>
                <td class="text-center py-4 px-4 text-[#00f5d4]">✓</td>
              </tr>
              <tr>
                <td class="py-4 px-4 text-white">Support</td>
                <td class="text-center py-4 px-4 text-[#8892b0]">Community</td>
                <td class="text-center py-4 px-4 text-[#00f5d4]">Priority Email</td>
                <td class="text-center py-4 px-4 text-[#a855f7]">Dedicated</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Testimonials -->
      <div class="max-w-6xl mx-auto px-4 py-16 border-t border-[#2a2a3a]">
        <h2 class="text-3xl font-bold text-white text-center mb-12">What Server Owners Say</h2>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {testimonials.map((t) => (
            <div class="p-6 bg-[#12121a] border border-[#2a2a3a] rounded-xl">
              <div class="flex gap-1 mb-4">
                {[1,2,3,4,5].map(() => (
                  <svg class="w-5 h-5 text-[#ffd700]" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                  </svg>
                ))}
              </div>
              <p class="text-white mb-4 italic">"{t.quote}"</p>
              <div class="flex items-center justify-between">
                <span class="text-[#8892b0] text-sm">— {t.author}</span>
                <span class={`text-xs px-2 py-1 rounded ${t.tier === 'Elite' ? 'bg-[#a855f7]/20 text-[#a855f7]' : 'bg-[#00f5d4]/20 text-[#00f5d4]'}`}>
                  {t.tier}
                </span>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- FAQ -->
      <div class="max-w-3xl mx-auto px-4 py-16 border-t border-[#2a2a3a]">
        <h2 class="text-3xl font-bold text-white text-center mb-12">Frequently Asked Questions</h2>
        
        <div class="space-y-4">
          {faqs.map((faq, i) => (
            <div class="bg-[#12121a] border border-[#2a2a3a] rounded-lg overflow-hidden">
              <button 
                class="w-full px-6 py-4 flex items-center justify-between text-left hover:bg-[#1a1a25] transition-colors"
                onclick={`document.getElementById('faq-${i}').classList.toggle('hidden')`}
              >
                <span class="text-white font-medium">{faq.q}</span>
                <svg class="w-5 h-5 text-[#8892b0]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
              <div id={`faq-${i}`} class="hidden px-6 pb-4">
                <p class="text-[#8892b0]">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- CTA Section -->
      <div class="max-w-4xl mx-auto px-4 py-16 text-center">
        <div class="p-8 md:p-12 bg-gradient-to-r from-[#00f5d4]/10 via-[#ff3864]/10 to-[#a855f7]/10 border border-[#2a2a3a] rounded-2xl">
          <h2 class="text-3xl font-bold text-white mb-4">Ready to Grow Your Server?</h2>
          <p class="text-[#8892b0] mb-8 max-w-xl mx-auto">
            Join 500+ server owners who trust GuildPost Premium to reach more players and grow their community.
          </p>
          <div class="flex flex-wrap items-center justify-center gap-4">
            <a href="/dashboard" class="px-8 py-4 bg-[#00f5d4] hover:bg-[#00d4b8] text-[#0a0a0f] font-bold rounded-lg transition-colors">
              Upgrade Now
            </a>
            <a href="/minecraft" class="px-8 py-4 bg-[#1a1a25] hover:bg-[#2a2a3a] text-white border border-[#2a2a3a] rounded-lg transition-colors">
              Browse Servers
            </a>
          </div>
        </div>
      </div>
    </main>

    <Footer />
  </div>
  
  <!-- Checkout Modal -->
  <div id="checkout-modal" class="fixed inset-0 bg-black/80 backdrop-blur-sm z-50 hidden flex items-center justify-center p-4">
    <div class="bg-[#12121a] border border-[#2a2a3a] rounded-2xl max-w-md w-full p-6 relative">
      <button id="close-modal" class="absolute top-4 right-4 text-[#8892b0] hover:text-white">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </button>
      
      <div class="text-center mb-6">
        <div class="w-12 h-12 bg-[#00f5d4]/20 rounded-full flex items-center justify-center mx-auto mb-3">
          <span class="text-2xl">⭐</span>
        </div>
        <h3 class="text-xl font-bold text-white">Upgrade to <span id="modal-tier-name">Premium</span></h3>
        <p class="text-[#8892b0] text-sm">Complete your subscription</p>
      </div>
      
      <form id="checkout-form" class="space-y-4">
        <div>
          <label class="text-[#8892b0] text-sm block mb-2">Server ID</label>
          <input 
            type="text" 
            id="server-id" 
            class="w-full px-3 py-2 bg-[#0a0a0f] border border-[#2a2a3a] rounded-lg text-white text-sm"
            placeholder="Enter your server ID"
            value={initialServerId}
          />
          <p class="text-[#8892b0] text-xs mt-1">Find this in your server URL: /servers/[id]</p>
        </div>
        
        <div>
          <label class="text-[#8892b0] text-sm block mb-2">Billing Email</label>
          <input 
            type="email" 
            id="billing-email" 
            class="w-full px-3 py-2 bg-[#0a0a0f] border border-[#2a2a3a] rounded-lg text-white text-sm"
            placeholder="your@email.com"
            required
          />
        </div>
        
        <div class="p-4 bg-[#0a0a0f] rounded-lg">
          <div class="flex justify-between items-center mb-2">
            <span class="text-white" id="summary-tier">Premium Plan</span>
            <span class="text-[#00f5d4] font-bold" id="summary-price">$9.99/mo</span>
          </div>
          <p class="text-[#8892b0] text-xs">Cancel anytime. Billed monthly.</p>
        </div>
        
        <button 
          type="submit" 
          id="checkout-submit"
          class="w-full py-3 bg-[#00f5d4] hover:bg-[#00d4b8] text-[#0a0a0f] font-bold rounded-lg transition-colors flex items-center justify-center gap-2"
        >
          <span id="checkout-text">Proceed to Checkout</span>
          <svg id="checkout-spinner" class="animate-spin hidden" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-6.219-8.56"></path></svg>
        </button>
      </form>
      
      <div class="mt-4 text-center">
        <p class="text-[#8892b0] text-xs">
          🔒 Secure payment via <span class="text-[#635BFF]">Stripe</span>
        </p>
      </div>
    </div>
  </div>
</Layout>

<script define:vars={{ initialServerId }}>
  // Modal functionality
  const modal = document.getElementById('checkout-modal');
  const closeBtn = document.getElementById('close-modal');
  const checkoutForm = document.getElementById('checkout-form');
  const serverIdInput = document.getElementById('server-id');
  const billingEmailInput = document.getElementById('billing-email');
  const modalTierName = document.getElementById('modal-tier-name');
  const summaryTier = document.getElementById('summary-tier');
  const summaryPrice = document.getElementById('summary-price');
  const checkoutSubmit = document.getElementById('checkout-submit');
  const checkoutText = document.getElementById('checkout-text');
  const checkoutSpinner = document.getElementById('checkout-spinner');
  
  let selectedTier = 'premium';
  let selectedPrice = '$9.99/mo';
  
  // Open modal when clicking upgrade buttons
  document.querySelectorAll('.checkout-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      selectedTier = btn.dataset.tier;
      selectedPrice = selectedTier === 'premium' ? '$9.99/mo' : '$29.99/mo';
      const tierName = selectedTier === 'premium' ? 'Premium' : 'Elite';
      
      modalTierName.textContent = tierName;
      summaryTier.textContent = tierName + ' Plan';
      summaryPrice.textContent = selectedPrice;
      
      modal.classList.remove('hidden');
    });
  });
  
  // Close modal
  closeBtn?.addEventListener('click', () => {
    modal.classList.add('hidden');
  });
  
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) modal.classList.add('hidden');
  });
  
  // Handle checkout
  checkoutForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const serverId = serverIdInput.value.trim();
    const email = billingEmailInput.value.trim();
    
    if (!serverId) {
      alert('Please enter your server ID');
      return;
    }
    
    if (!email || !email.includes('@')) {
      alert('Please enter a valid email address');
      return;
    }
    
    // Show loading
    checkoutSubmit.disabled = true;
    checkoutText.textContent = 'Creating checkout...';
    checkoutSpinner.classList.remove('hidden');
    
    try {
      const response = await fetch('/api/stripe/checkout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          serverId: serverId,
          tier: selectedTier,
          email: email,
          successUrl: `${window.location.origin}/dashboard?upgrade=success`,
          cancelUrl: `${window.location.origin}/premium?upgrade=canceled`,
        }),
      });
      
      const result = await response.json();
      
      if (response.ok && result.url) {
        // Redirect to Stripe Checkout
        window.location.href = result.url;
      } else {
        alert(result.error || 'Failed to create checkout. Please try again.');
        checkoutSubmit.disabled = false;
        checkoutText.textContent = 'Proceed to Checkout';
        checkoutSpinner.classList.add('hidden');
      }
    } catch (err) {
      console.error('Checkout error:', err);
      alert('Network error. Please try again.');
      checkoutSubmit.disabled = false;
      checkoutText.textContent = 'Proceed to Checkout';
      checkoutSpinner.classList.add('hidden');
    }
  });
</script>